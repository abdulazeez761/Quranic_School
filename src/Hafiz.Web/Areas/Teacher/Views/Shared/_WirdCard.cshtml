@using Hafiz.Common.Helper
@model Hafiz.Models.WirdAssignment
@inject Microsoft.AspNetCore.Mvc.Localization.IViewLocalizer Localizer

@{
    var statusClass = Model.Status.ToString().ToLower();
    var statusKey = Model.Status.ToString();
    var localizedStatus = Localizer[char.ToUpper(statusKey[0]) + statusKey.Substring(1)];
}
<div id="wird-card-@Model.Id" class="wird-card @statusClass"
     data-student="@Model.Student.StudentInfo.FirstName @Model.Student.StudentInfo.SecondName" data-type="@Model.Type"
     data-status="@statusClass" data-date="@Model.AssignedDate.ToString("yyyy-MM-dd")">

    <div class="wird-card-top-stripe"></div>

    <!-- HEADER: name + badge inline, meta row below -->
    <div class="wird-card-header">
        <div class="wird-header-title">
            <h3 class="student-name">@Model.Student.StudentInfo.FirstName @Model.Student.StudentInfo.SecondName</h3>
            <span class="wird-status-badge status-@statusClass">@localizedStatus</span>
        </div>
        <div class="wird-meta">
            <span class="wird-type-badge">
                <i class='bx bx-bookmark'></i>
                @Localizer[Model.Type.ToString()]
            </span>
            @if (Model.Amount.HasValue && Model.AmountUnit.HasValue)
            {
                var unitKey = Model.AmountUnit.Value switch
                {
                    WirdUnit.Pages => "UnitPages",
                    WirdUnit.Ayahs => "UnitAyahs",
                    WirdUnit.Juz => "UnitJuz",
                    _ => ""
                };
                <span class="wird-amount-badge">
                    <i class='bx bx-collection'></i>
                    @Model.Amount.Value.ToString("0.##") @Localizer[unitKey]
                </span>
            }
            <span class="wird-date-badge">
                <i class='bx bx-calendar'></i>
                @Model.AssignedDate.ToString("MMM dd")
            </span>
        </div>
    </div>

    <!-- QURAN RANGE -->
    <div class="wird-range-compact">
        <div class="range-item">
            <span class="range-label">@Localizer["From"]</span>
            <span class="range-value">
                @Formatting.GetLocalizedSurahName(Model.FromSurah ?? Surah.NONE)
                @Localizer["Ayah"] @Model.FromAyah
            </span>
            <span class="range-detail">@Localizer["Juz"] @Model.FromJuz · @Localizer["Page"] @Model.FromPage</span>
        </div>
        <div class="range-divider">
            <i class='bx bx-right-arrow-alt'></i>
        </div>
        <div class="range-item">
            <span class="range-label">@Localizer["To"]</span>
            <span class="range-value">
                @Formatting.GetLocalizedSurahName(Model.ToSurah ?? Surah.NONE)
                @Localizer["Ayah"] @Model.ToAyah
            </span>
            <span class="range-detail">@Localizer["Juz"] @Model.ToJuz · @Localizer["Page"] @Model.ToPage</span>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.Note))
    {
        <div class="wird-note">
            <i class='bx bx-note'></i>
            <p>@Model.Note</p>
        </div>
    }

    <!-- NOTES EDIT SECTION (Hidden by default) -->
    <div class="notes-edit" id="notes-edit-@Model.Id" style="display: none;">
        <textarea class="notes-textarea" id="notes-textarea-@Model.Id"
                  placeholder="@Localizer["AddNotes"]">@Model.Note</textarea>
        <div class="notes-edit-actions">
            <button class="btn btn-success btn-sm save-note-btn" data-assignment-id="@Model.Id">@Localizer["Save"]</button>
            <button class="btn btn-secondary btn-sm cancel-note-btn" data-assignment-id="@Model.Id">@Localizer["Cancel"]</button>
        </div>
    </div>

    <!-- FOOTER: segmented rating + actions -->
    <div class="card-footer">
        <div class="rating-segmented">
            <button class="seg-btn seg-excellent status-button" data-status="@AssignmentStatus.excellent"
                    data-id="@Model.Id" title="@Localizer["Excellent"]">@Localizer["Excellent"]</button>
            <button class="seg-btn seg-verygood status-button" data-status="@AssignmentStatus.veryGood"
                    data-id="@Model.Id" title="@Localizer["VeryGood"]">@Localizer["VeryGood"]</button>
            <button class="seg-btn seg-good status-button" data-status="@AssignmentStatus.good"
                    data-id="@Model.Id" title="@Localizer["Good"]">@Localizer["Good"]</button>
            <button class="seg-btn seg-fair status-button" data-status="@AssignmentStatus.fair"
                    data-id="@Model.Id" title="@Localizer["Fair"]">@Localizer["Fair"]</button>
            <button class="seg-btn seg-poor status-button" data-status="@AssignmentStatus.poor"
                    data-id="@Model.Id" title="@Localizer["Poor"]">@Localizer["Poor"]</button>
        </div>
        <div class="card-actions">
            <button class="card-action-btn" data-assignment-id="@Model.Id" title="@Localizer["AddNotes"]">
                <i class='bx bx-note'></i>
            </button>
            <button class="card-action-btn" onclick="
                fetchWirdAssignmentById('@Model.Id');
                openWirdModal('@Model.StudentId', '@Model.Student.StudentInfo.FirstName @Model.Student.StudentInfo.SecondName');"
                    title="@Localizer["Edit"]">
                <i class='bx bx-edit'></i>
            </button>
            <form method="post" asp-controller="Wird" asp-action="Delete" asp-route-id="@Model.Id"
                  class="d-inline delete-form">
                <button type="submit" class="card-action-btn danger"
                        data-confirm-delete="@Localizer["ConfirmDelete"] @Model.Student.StudentInfo.FirstName @Model.Student.StudentInfo.SecondName">
                    <i class='bx bx-trash'></i>
                </button>
            </form>
        </div>
    </div>

</div>
