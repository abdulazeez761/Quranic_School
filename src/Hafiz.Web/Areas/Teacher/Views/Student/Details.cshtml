@using Hafiz.Models
@using Hafiz.DTOs.Student
@using Hafiz.Common.Helper
@using System.Security.Claims
@model StudentDetailsViewModel

@inject Microsoft.AspNetCore.Mvc.Localization.IViewLocalizer Localizer

@{
    ViewData["Title"] = Localizer["StudentDetails"].Value;
    var studentFullName = $"{Model.Student.StudentInfo.FirstName} {Model.Student.StudentInfo.SecondName}";
    var age = DateTime.Now.Year - Model.Student.DateOfBirth.Year;
}

<link rel="stylesheet" href="~/css/teacher/Students.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/teacher/student-details.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/variables.css" asp-append-version="true" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" asp-append-version="true">

<a href="@Url.Action("Index", "Student")" class="back-button">
    <i class="bi bi-arrow-left"></i>
    @Localizer["BackToStudents"]
</a>

@{
    var totalMemorizedPages = WirdPageCalculator.TotalMemorizedPages(Model.Student);
    var (memorizedJuzDisplay, memorizedPagesRemainder) = WirdPageCalculator.SplitJuzAndPages(totalMemorizedPages);
    var memorizationPercent = (int)Math.Round((double)totalMemorizedPages / WirdPageCalculator.TotalQuranPages * 100);
    if (memorizationPercent > 100) memorizationPercent = 100;
    var isHafiz = WirdPageCalculator.IsHafiz(Model.Student);
    var reviewedPages = Model.Student.ReviewedPages;
    var (reviewedJuzDisplay, reviewedPagesRemainder) = WirdPageCalculator.SplitJuzAndPages(reviewedPages);
}

<!-- Student Details Header -->
<div class="details-header">
    <div class="details-header-pattern"></div>
    <div class="details-header-content">
        <div class="student-avatar">
            @(Model.Student.StudentInfo.FirstName.Length > 0 ? Model.Student.StudentInfo.FirstName[0] : "S")
        </div>
        <div class="student-basic-info">
            <h1>
                @studentFullName
                @if (isHafiz)
                {
                    <span class="hafiz-badge" title="@Localizer["HafizTitle"]">
                        <i class="bi bi-award-fill"></i> @Localizer["Hafiz"]
                    </span>
                }
            </h1>
            <div class="student-meta-chips">
                <span class="meta-chip"><i class="bi bi-calendar"></i> @age @Localizer["Years"]</span>
                @if (!string.IsNullOrEmpty(Model.Student.StudentInfo.PhoneNumber))
                {
                    <span class="meta-chip"><i class="bi bi-telephone"></i> @Model.Student.StudentInfo.PhoneNumber</span>
                }
                @if (!string.IsNullOrEmpty(Model.Student.StudentInfo.Email))
                {
                    <span class="meta-chip"><i class="bi bi-envelope"></i> @Model.Student.StudentInfo.Email</span>
                }
            </div>
        </div>
        <div class="student-progress-card">
            <div class="progress-card-label">
                <i class="bi bi-book-half"></i>
                @Localizer["MemorizedJuz"]
            </div>
            <div class="progress-card-value">
                <span class="progress-current">@memorizedJuzDisplay</span>
                <span class="progress-total">/ 30</span>
            </div>
            @if (memorizedPagesRemainder > 0)
            {
                <div class="progress-card-subtext">
                    + @memorizedPagesRemainder.ToString("0.##") @Localizer["UnitPages"]
                </div>
            }
            <div class="progress-card-bar">
                <div class="progress-card-fill" style="width: @memorizationPercent%"></div>
            </div>
            <div class="progress-card-percent">@memorizationPercent%</div>
        </div>
    </div>
</div>

<!-- Memorization & Review Stats -->
<div class="progress-stats-row">
    <div class="progress-stat-card stat-memorized">
        <div class="progress-stat-icon"><i class="bi bi-bookmark-check-fill"></i></div>
        <div class="progress-stat-body">
            <div class="progress-stat-label">@Localizer["MemorizedPages"]</div>
            <div class="progress-stat-value">@totalMemorizedPages.ToString("0.##")</div>
            <div class="progress-stat-sub">
                @memorizedJuzDisplay @Localizer["JuzShort"]
                @if (memorizedPagesRemainder > 0)
                {
                    <text>+ @memorizedPagesRemainder.ToString("0.##") @Localizer["UnitPages"]</text>
                }
            </div>
        </div>
    </div>
    <div class="progress-stat-card stat-reviewed">
        <div class="progress-stat-icon"><i class="bi bi-arrow-repeat"></i></div>
        <div class="progress-stat-body">
            <div class="progress-stat-label">@Localizer["ReviewedPages"]</div>
            <div class="progress-stat-value">@reviewedPages.ToString("0.##")</div>
            <div class="progress-stat-sub">
                @reviewedJuzDisplay @Localizer["JuzShort"]
                @if (reviewedPagesRemainder > 0)
                {
                    <text>+ @reviewedPagesRemainder.ToString("0.##") @Localizer["UnitPages"]</text>
                }
            </div>
        </div>
    </div>
    <div class="progress-stat-card stat-reviewed-juz">
        <div class="progress-stat-icon"><i class="bi bi-collection-fill"></i></div>
        <div class="progress-stat-body">
            <div class="progress-stat-label">@Localizer["ReviewedJuz"]</div>
            <div class="progress-stat-value">@reviewedJuzDisplay</div>
            <div class="progress-stat-sub">@Localizer["CompletedJuzReviews"]</div>
        </div>
    </div>
</div>

<!-- Student Information -->
<div class="details-container">
    <!-- Academic Info -->
    <div class="info-card info-card-academic">
        <h3>
            <span class="info-card-icon"><i class="bi bi-book"></i></span>
            @Localizer["AcademicInformation"]
        </h3>
        <div class="info-row">
            <span class="info-label">@Localizer["MemorizedJuz"]:</span>
            <span class="info-value">
                @memorizedJuzDisplay / 30
                @if (memorizedPagesRemainder > 0)
                {
                    <small>(+ @memorizedPagesRemainder.ToString("0.##") @Localizer["UnitPages"])</small>
                }
            </span>
        </div>
        <div class="info-row">
            <span class="info-label">@Localizer["TajwidLevel"]:</span>
            <span class="info-value">@Localizer[Model.Student.TajwidLevel.ToString()]</span>
        </div>
        <div class="info-row">
            <span class="info-label">@Localizer["Gender"]:</span>
            <span class="info-value">@Localizer[Model.Student.sex.ToString()]</span>
        </div>
        <div class="info-row">
            <span class="info-label">@Localizer["DateOfBirth"]:</span>
            <span class="info-value">@Model.Student.DateOfBirth.ToString("yyyy-MM-dd")</span>
        </div>
    </div>

    <!-- Contact & Family Info -->
    <div class="info-card info-card-contact">
        <h3>
            <span class="info-card-icon"><i class="bi bi-person-heart"></i></span>
            @Localizer["ContactInformation"]
        </h3>
        <div class="info-row">
            <span class="info-label">@Localizer["Phone"]:</span>
            <span class="info-value">@Model.Student.StudentInfo.PhoneNumber</span>
        </div>
        <div class="info-row">
            <span class="info-label">@Localizer["Email"]:</span>
            <span class="info-value">@Model.Student.StudentInfo.Email</span>
        </div>
        @if (Model.Student.Parent != null)
        {
            <div class="info-row">
                <span class="info-label">@Localizer["Parent"]:</span>
                <span class="info-value">@Model.Student.Parent.ParentInfo?.FirstName @Model.Student.Parent.ParentInfo?.SecondName</span>
            </div>
        }
        <div class="info-row">
            <span class="info-label">@Localizer["ClassesEnrolled"]:</span>
            <span class="info-value">@(Model.Student.Classes?.Count ?? 0)</span>
        </div>
    </div>
</div>

<!-- Wirds Section -->
<div class="wirds-section">
    <h3>
        <span class="section-icon section-icon-wirds"><i class="bi bi-list-check"></i></span>
        @Localizer["AssignedWirds"]
        <span class="section-count-pill">@Model.TotalWirds</span>
    </h3>

    @if (Model.PaginatedWirds != null && Model.PaginatedWirds.Any())
    {
        <div class="wirds-list">
            @foreach (var wird in Model.PaginatedWirds)
            {
                var fromSurahName = wird.FromSurah != null && wird.FromSurah != Surah.NONE
                    ? Formatting.GetLocalizedSurahName(wird.FromSurah.Value)
                    : null;
                var toSurahName = wird.ToSurah != null && wird.ToSurah != Surah.NONE
                    ? Formatting.GetLocalizedSurahName(wird.ToSurah.Value)
                    : null;

                var hasFromData = fromSurahName != null || wird.FromJuz != null || wird.FromPage != null || !string.IsNullOrEmpty(wird.FromAyah);
                var hasToData = toSurahName != null || wird.ToJuz != null || wird.ToPage != null || wird.ToAyah != null;

                <div class="wird-item">
                    <div class="wird-header">
                        <h4>@Localizer[wird.Type.ToString()]</h4>
                        <span class="wird-status-badge @(wird.IsCompleted ? "status-completed" : wird.Status == AssignmentStatus.notSet ? "status-pending" : "")">
                            @Localizer[wird.Status.ToString()]
                        </span>
                    </div>

                    <div class="wird-meta-row">
                        <span><i class="bi bi-calendar3"></i> @Localizer["Assigned"] @wird.AssignedDate.ToString("MMM dd, yyyy")</span>
                        @if (wird.IsCompleted)
                        {
                            <span class="wird-completed-badge"><i class="bi bi-check-circle-fill"></i> @Localizer["Completed"]</span>
                        }
                    </div>

                    @if (hasFromData || hasToData)
                    {
                        <div class="wird-range-compact">
                            @if (hasFromData)
                            {
                                <div class="wird-range-line">
                                    <strong>@Localizer["From"]</strong>
                                    <span class="wird-range-values">
                                        @if (fromSurahName != null)
                                        {
                                            <span>@Localizer["Surah"] <b>@fromSurahName</b></span>
                                        }
                                        @if (wird.FromJuz != null)
                                        {
                                            <span>@Localizer["Juz"] <b>@wird.FromJuz</b></span>
                                        }
                                        @if (wird.FromPage != null)
                                        {
                                            <span>@Localizer["Page"] <b>@wird.FromPage</b></span>
                                        }
                                        @if (!string.IsNullOrEmpty(wird.FromAyah))
                                        {
                                            <span>@Localizer["Ayah"] <b>@wird.FromAyah</b></span>
                                        }
                                    </span>
                                </div>
                            }
                            @if (hasToData)
                            {
                                <div class="wird-range-line">
                                    <strong>@Localizer["To"]</strong>
                                    <span class="wird-range-values">
                                        @if (toSurahName != null)
                                        {
                                            <span>@Localizer["Surah"] <b>@toSurahName</b></span>
                                        }
                                        @if (wird.ToJuz != null)
                                        {
                                            <span>@Localizer["Juz"] <b>@wird.ToJuz</b></span>
                                        }
                                        @if (wird.ToPage != null)
                                        {
                                            <span>@Localizer["Page"] <b>@wird.ToPage</b></span>
                                        }
                                        @if (wird.ToAyah != null)
                                        {
                                            <span>@Localizer["Ayah"] <b>@wird.ToAyah</b></span>
                                        }
                                    </span>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="wird-range-compact">
                            <span class="wird-not-specified">@Localizer["NotSpecified"]</span>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(wird.Note))
                    {
                        <div class="wird-note-compact">
                            <strong>@Localizer["Notes"]</strong>
                            <span>@wird.Note</span>
                        </div>
                    }
                </div>
            }
        </div>

        <!-- Pagination Controls -->
        @if (Model.TotalPages > 1)
        {
            <div class="pagination-controls">
                @if (Model.HasPrevious)
                {
                    <a href="@Url.Action("Details", "Student", new { id = Model.Student.UserId, page = Model.CurrentPage - 1 })"
                       class="pagination-btn">
                        <i class="bi bi-chevron-left"></i>
                        @Localizer["Previous"]
                    </a>
                }

                <span class="pagination-info">
                    @string.Format(Localizer["PageOf"].Value, Model.CurrentPage, Model.TotalPages)
                </span>

                @if (Model.HasNext)
                {
                    <a href="@Url.Action("Details", "Student", new { id = Model.Student.UserId, page = Model.CurrentPage + 1 })"
                       class="pagination-btn">
                        @Localizer["Next"]
                        <i class="bi bi-chevron-right"></i>
                    </a>
                }
            </div>
        }
    }
    else
    {
        <div class="empty-state">
            <i class="bi bi-inbox"></i>
            <p>@Localizer["NoWirdsYet"]</p>
        </div>
    }
</div>

<!-- Parent Notes Section -->
<div class="wirds-section notes-section">
    <h3>
        <span class="section-icon section-icon-notes"><i class="bi bi-sticky"></i></span>
        @Localizer["ParentNotes"]
        @if (ViewBag.ParentNotes is IEnumerable<Hafiz.Models.ParentNote> notesForCount)
        {
            <span class="section-count-pill">@notesForCount.Count()</span>
        }
    </h3>

    @{
        var parentNotes = ViewBag.ParentNotes as IEnumerable<Hafiz.Models.ParentNote> ?? new List<Hafiz.Models.ParentNote>();
    }

    <!-- Add New Note Form -->
    <div class="note-form-container">
        <h4>@Localizer["AddNewNote"]</h4>
        <form asp-area="Teacher" asp-controller="ParentNotes" asp-action="Create" method="post">
            <input type="hidden" name="studentId" value="@Model.Student.UserId" />
            <div class="note-form-field">
                <textarea name="content" rows="2"
                          class="note-textarea"
                          placeholder="@Localizer["WritePlaceholder"]" required></textarea>
            </div>
            <button type="submit" class="note-submit-btn">
                <i class="bi bi-plus-circle"></i> @Localizer["AddNote"]
            </button>
        </form>
    </div>

    <!-- Display Existing Notes -->
    @if (parentNotes.Any())
    {
        <div class="wirds-list">
            @foreach (var note in parentNotes)
            {
                <div class="note-item">
                    <div class="note-header">
                        <div>
                            <div class="note-author">
                                <i class="bi bi-person-circle"></i> @Localizer["By"] @note.CreatedByUser.FirstName @note.CreatedByUser.SecondName
                            </div>
                            <div class="note-date">
                                <i class="bi bi-calendar"></i> @note.CreatedAt.ToString("MMM dd, yyyy 'at' h:mm tt")
                                @if (note.UpdatedAt != null)
                                {
                                    <span> @Localizer["Updated"] @note.UpdatedAt.Value.ToString("MMM dd, yyyy"))</span>
                                }
                            </div>
                        </div>
                        @if (note.CreatedBy == Guid.Parse(User.FindFirstValue(System.Security.Claims.ClaimTypes.NameIdentifier)!))
                        {
                            <form asp-area="Teacher" asp-controller="ParentNotes" asp-action="Delete" method="post"
                                  style="display: inline;" onsubmit="return confirm('@Localizer["ConfirmDeleteNote"]');">
                                <input type="hidden" name="noteId" value="@note.Id" />
                                <input type="hidden" name="studentId" value="@Model.Student.UserId" />
                                <button type="submit" class="note-delete-btn" title="Delete note">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        }
                    </div>
                    <div class="note-content">
                        <p>@note.Content</p>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state">
            <i class="bi bi-sticky"></i>
            <p>@Localizer["NoNotesYet"]</p>
        </div>
    }
</div>
