@using Hafiz.Models
@using Hafiz.Models.enums
@model IEnumerable<Student>

@inject Microsoft.AspNetCore.Mvc.Localization.IViewLocalizer Localizer

@{
    var pageTitle = Localizer["PageTitle"].Value;

    var classId = ViewBag.ClassId != null ? Guid.Parse(ViewBag.ClassId.ToString()) : Guid.Empty;
    var className = Model.FirstOrDefault()?.Classes.FirstOrDefault(c => c.Id == classId)?.Name
                    ?? Localizer["Students"].Value;

    var students = Model?.ToList() ?? new List<Student>();
    var totalStudents = students.Count;
    var boysCount = students.Count(s => s.sex == Sex.male);
    var girlsCount = students.Count(s => s.sex == Sex.female);
    var avgAge = totalStudents > 0
        ? (int)Math.Round(students.Average(s => DateTime.Now.Year - s.DateOfBirth.Year))
        : 0;
}

<link rel="stylesheet" href="~/css/teacher/Students.css" asp-append-version="true" />

<div class="students-page">

    <div class="class-header">
        <div class="class-header-left">
            <div class="class-header-title">
                <i class='bx bx-book-reader header-icon'></i>
                <div>
                    <h2>@className</h2>
                    <p>
                        <span>@totalStudents @Localizer["Students"]</span>
                        @if (totalStudents > 0)
                        {
                            <span class="header-dot">•</span>
                            if (boysCount > 0)
                            {
                                <span class="header-meta-item">
                                    <i class='bx bx-male'></i>@boysCount @Localizer["Boys"]
                                </span>
                            }
                            if (girlsCount > 0)
                            {
                                <span class="header-meta-item">
                                    <i class='bx bx-female'></i>@girlsCount @Localizer["Girls"]
                                </span>
                            }
                        }
                    </p>
                </div>
            </div>
        </div>
        <a class="change-class-btn" asp-action="Index" asp-controller="Home">
            <i class='bx bx-transfer-alt'></i>
            <span>@Localizer["ChangeClass"]</span>
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert" id="successAlert">
            <i class="bi bi-check-circle-fill me-2"></i>
            <strong>@Localizer["Success"]</strong> @TempData["SuccessMessage"]
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert" id="errorAlert">
            <i class="bi bi-x-circle-fill me-2"></i>
            <strong>@Localizer["Error"]</strong> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (totalStudents > 0)
    {
        <div class="students-toolbar">
            <div class="search-wrapper">
                <i class='bx bx-search search-icon'></i>
                <input id="studentSearch" type="text" class="search-input" placeholder="@Localizer["SearchPlaceholder"]"
                       autocomplete="off" />
            </div>
            @* <div class="filter-pills" role="tablist" aria-label="@Localizer["TajwidLevel"]">
                <button type="button" class="filter-pill active" data-level="all">@Localizer["All"]</button>
                <button type="button" class="filter-pill" data-level="First">@Localizer["First"]</button>
                <button type="button" class="filter-pill" data-level="Second">@Localizer["Second"]</button>
                <button type="button" class="filter-pill" data-level="Third">@Localizer["Third"]</button>
            </div> *@
        </div>
    }

    <div class="students-grid" id="studentsGrid">
        @foreach (Student student in students)
        {
            var age = DateTime.Now.Year - student.DateOfBirth.Year;
            var activeWirds = student.wirds?.Count(w => w.Status == AssignmentStatus.notSet) ?? 0;
            var completedWirds = student.wirds?.Count(w => w.Status != AssignmentStatus.notSet) ?? 0;
            var firstName = student.StudentInfo?.FirstName ?? string.Empty;
            var secondName = student.StudentInfo?.SecondName ?? string.Empty;
            var studentFullName = $"{firstName} {secondName}".Trim();
            var initials = ((firstName.Length > 0 ? firstName[0].ToString() : "")
                            + (secondName.Length > 0 ? secondName[0].ToString() : "")).ToUpper();
            var genderClass = student.sex == Sex.female ? "female" : "male";
            var tajwidClass = student.TajwidLevel.ToString().ToLower();
            var juzPercent = Math.Min(100, (int)((student.MemorizedJuz / 30.0) * 100));
            var searchKey = studentFullName.ToLower();

            <div class="student-card" data-name="@searchKey" data-level="@student.TajwidLevel"
                 data-juz="@student.MemorizedJuz">

                <div class="student-card-stripe stripe-@genderClass"></div>

                <div class="student-card-header">
                    <div class="student-avatar avatar-@genderClass" aria-hidden="true">
                        @if (!string.IsNullOrWhiteSpace(initials))
                        {
                            <span>@initials</span>
                        }
                        else
                        {
                            <i class='bx bx-user'></i>
                        }
                    </div>
                    <div class="student-identity">
                        <h3 class="student-name" title="@studentFullName">@studentFullName</h3>
                        <div class="student-tags">
                            <span class="chip chip-age">
                                <i class='bx bx-cake'></i>@age @Localizer["Years"]
                            </span>
                            <span class="chip chip-tajwid tajwid-@tajwidClass">
                                <i class='bx bx-medal'></i>@Localizer[student.TajwidLevel.ToString()]
                            </span>
                        </div>
                    </div>
                    <span class="active-badge @(activeWirds == 0 ? "zero" : "")" title="@Localizer["ActiveWirds"]">
                        <i class='bx bx-pulse'></i>@activeWirds
                    </span>
                </div>

                <div class="memorization-block">
                    <div class="memorization-head">
                        <span class="memorization-label">
                            <i class='bx bx-book-bookmark'></i>@Localizer["JuzMemorized"]
                        </span>
                        <span class="memorization-value">@student.MemorizedJuz / 30</span>
                    </div>
                    <div class="memorization-bar" role="progressbar" aria-valuenow="@student.MemorizedJuz" aria-valuemin="0"
                         aria-valuemax="30">
                        <div class="memorization-fill" style="width: @juzPercent%"></div>
                    </div>
                </div>

                <div class="student-stats">
                    <div class="stat-item">
                        <i class='bx bx-time-five stat-icon'></i>
                        <div class="stat-text">
                            <span class="stat-value">@activeWirds</span>
                            <span class="stat-label">@Localizer["ActiveWirds"]</span>
                        </div>
                    </div>
                    <div class="stat-divider"></div>
                    <div class="stat-item">
                        <i class='bx bx-check-circle stat-icon'></i>
                        <div class="stat-text">
                            <span class="stat-value">@completedWirds</span>
                            <span class="stat-label">@Localizer["CompletedWirds"]</span>
                        </div>
                    </div>
                </div>

                <div class="student-actions">
                    <a asp-action="Details" asp-route-id="@student.UserId" class="btn btn-outline">
                        <i class='bx bx-show'></i>
                        <span>@Localizer["ViewDetails"]</span>
                    </a>
                    <button class="btn btn-primary" onclick="openWirdModal('@student.UserId', '@studentFullName')">
                        <span class="plus-icon">+</span>
                        <span>@Localizer["AddWird"]</span>
                    </button>
                </div>
            </div>
        }
    </div>

    <div class="students-empty" id="studentsEmpty" style="display: @(totalStudents == 0 ? "flex" : "none");">
        <div class="empty-icon"><i class='bx bx-user-x'></i></div>
        <h3>@Localizer["NoStudents"]</h3>
        <p>@Localizer["NoStudentsSubtitle"]</p>
    </div>

    <div class="students-empty no-match" id="studentsNoMatch" style="display: none;">
        <div class="empty-icon"><i class='bx bx-search-alt'></i></div>
        <h3>@Localizer["NoMatch"]</h3>
    </div>

</div>

<script>
    setTimeout(function () {
        const successAlert = document.getElementById('successAlert');
        const errorAlert = document.getElementById('errorAlert');

        if (successAlert) {
            successAlert.style.opacity = '0';
            setTimeout(() => successAlert.style.display = 'none', 500);
        }
        if (errorAlert) {
            errorAlert.style.opacity = '0';
            setTimeout(() => errorAlert.style.display = 'none', 500);
        }
    }, 5000);

    (function () {
        const searchInput = document.getElementById('studentSearch');
        const pills = document.querySelectorAll('.filter-pill');
        const cards = document.querySelectorAll('#studentsGrid .student-card');
        const noMatch = document.getElementById('studentsNoMatch');
        const grid = document.getElementById('studentsGrid');

        let activeLevel = 'all';
        let activeQuery = '';

        function applyFilters() {
            let visible = 0;
            cards.forEach(card => {
                const name = card.getAttribute('data-name') || '';
                const level = card.getAttribute('data-level') || '';
                const matchesQuery = activeQuery === '' || name.indexOf(activeQuery) !== -1;
                const matchesLevel = activeLevel === 'all' || level === activeLevel;
                const show = matchesQuery && matchesLevel;
                card.style.display = show ? '' : 'none';
                if (show) visible++;
            });
            if (noMatch) noMatch.style.display = visible === 0 && cards.length > 0 ? 'flex' : 'none';
            if (grid) grid.style.display = visible === 0 && cards.length > 0 ? 'none' : '';
        }

        if (searchInput) {
            searchInput.addEventListener('input', function () {
                activeQuery = this.value.trim().toLowerCase();
                applyFilters();
            });
        }

        pills.forEach(pill => {
            pill.addEventListener('click', function () {
                pills.forEach(p => p.classList.remove('active'));
                this.classList.add('active');
                activeLevel = this.getAttribute('data-level');
                applyFilters();
            });
        });
    })();
</script>

<!-- Include the modal partial view -->
@await Html.PartialAsync("_AssignWirdModal", new WirdAssignment())
