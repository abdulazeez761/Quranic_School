@model IEnumerable<Hafiz.Models.Parent>
@inject Microsoft.AspNetCore.Mvc.Localization.IViewLocalizer Localizer

@{
    ViewData["Title"] = @Localizer["Title"];
}

<!-- Page Header -->
<div class="d-flex justify-between align-center mb-lg flex-wrap gap-md">
    <div>
        <h2 class="section-title mb-sm">
            <i class='bx bx-user-circle' style="color: var(--primary-green);"></i>
            @Localizer["PageTitle"]
        </h2>
        <p class="text-medium">@Localizer["PageDescription"]</p>
    </div>
    <div class="btn-group">
        <a asp-action="Create" class="btn btn-primary">
            <i class='bx bx-user-plus'></i>
            <span>@Localizer["AddNewParent"]</span>
        </a>
        <button class="btn btn-outline" id="exportBtn">
            <i class='bx bx-download'></i>
            <span>@Localizer["Export"]</span>
        </button>
    </div>
</div>

<!-- Statistics Cards -->
@{
    var totalParents = Model.Count();
    var parentsWithChildren = Model.Count(p => p.Students != null && p.Students.Any());
    var parentsWithoutChildren = totalParents - parentsWithChildren;
    var totalChildren = Model.Sum(p => p.Students?.Count ?? 0);
}

<div class="grid-auto-fit mb-lg">
    <div class="card card-stat">
        <div class="card-stat-icon">
            <i class='bx bx-user-circle'></i>
        </div>
        <div class="card-stat-content">
            <div class="card-stat-label">@Localizer["TotalParents"]</div>
            <div class="card-stat-value">@totalParents</div>
        </div>
    </div>

    <div class="card card-stat">
        <div class="card-stat-icon" style="background: var(--success);">
            <i class='bx bx-check-circle'></i>
        </div>
        <div class="card-stat-content">
            <div class="card-stat-label">@Localizer["WithChildren"]</div>
            <div class="card-stat-value">@parentsWithChildren</div>
        </div>
    </div>

    <div class="card card-stat">
        <div class="card-stat-icon" style="background: var(--warning);">
            <i class='bx bx-error'></i>
        </div>
        <div class="card-stat-content">
            <div class="card-stat-label">@Localizer["WithoutChildren"]</div>
            <div class="card-stat-value">@parentsWithoutChildren</div>
        </div>
    </div>

    <div class="card card-stat">
        <div class="card-stat-icon" style="background: var(--info);">
            <i class='bx bx-group'></i>
        </div>
        <div class="card-stat-content">
            <div class="card-stat-label">@Localizer["TotalChildren"]</div>
            <div class="card-stat-value">@totalChildren</div>
        </div>
    </div>
</div>

<!-- Parents Table -->
<div class="table-container">
    <!-- Search Toolbar -->
    <div class="table-toolbar">
        <div class="table-search">
            <input type="text" id="searchInput" placeholder="@Localizer["SearchPlaceholder"]">
            <i class='bx bx-search'></i>
        </div>
        <div class="table-filters">
            <button id="clearFilters" class="btn btn-outline btn-sm">
                <i class='bx bx-refresh'></i>
                <span class="d-none d-md-inline">@Localizer["Reset"]</span>
            </button>
        </div>
    </div>

    <!-- Records grid -->
    <div class="record-grid" id="parentsGrid">
        @if (Model != null && Model.Any())
        {
            int index = 0;
            foreach (var parent in Model)
            {
                var childrenCount = parent.Students?.Count ?? 0;
                var hasChildren = childrenCount > 0;
                var avatarVariant = index % 5;

                <div class="record-card" data-firstname="@parent.ParentInfo.FirstName.ToLower()"
                     data-secondname="@parent.ParentInfo.SecondName.ToLower()">

                    <div class="record-card-header">
                        <div class="record-avatar record-avatar--@avatarVariant">
                            @parent.ParentInfo.FirstName.Substring(0, 1)
                        </div>
                        <div class="record-identity">
                            <span class="record-name">@parent.ParentInfo.FirstName @parent.ParentInfo.SecondName</span>
                            @if (hasChildren)
                            {
                                <span class="record-badge record-badge--green">
                                    <i class='bx bx-group'></i>
                                    <span>@childrenCount @Localizer["ChildrenCount"]</span>
                                </span>
                            }
                            else
                            {
                                <span class="record-badge record-badge--empty">
                                    <i class='bx bx-info-circle'></i>
                                    <span>@Localizer["NoChildren"]</span>
                                </span>
                            }
                        </div>
                    </div>

                    <div class="record-info">
                        <div class="record-info-row">
                            <i class='bx bx-user'></i>
                            <span class="record-info-value" title="@parent.ParentInfo.Username">@parent.ParentInfo.Username</span>
                        </div>
                        <div class="record-info-row">
                            <i class='bx bx-phone'></i>
                            <span class="record-info-value">@parent.ParentInfo.PhoneNumber</span>
                        </div>
                    </div>

                    <div class="record-actions">
                        <a asp-action="Edit" asp-route-id="@parent.UserId" class="record-btn record-btn-edit">
                            <i class='bx bx-edit'></i>
                            <span>@Localizer["Edit"]</span>
                        </a>
                        <form asp-action="Delete" asp-route-id="@parent.UserId" method="post" class="delete-form">
                            <button type="submit" class="record-btn record-btn-delete"
                                    data-confirm-delete="@string.Format(Localizer["DeleteConfirmation"].Value, parent.ParentInfo.FirstName, parent.ParentInfo.SecondName)"
                                    data-tooltip="@Localizer["Delete"]">
                                <i class='bx bx-trash'></i>
                            </button>
                        </form>
                    </div>
                </div>
                index++;
            }
        }
        else
        {
            <div class="record-empty">
                <i class='bx bx-user-x'></i>
                <h3 class="record-empty-title">@Localizer["NoDataAvailable"]</h3>
                <p class="text-medium">@Localizer["NoParentsAdded"]</p>
                <a asp-action="Create" class="btn btn-primary mt-md">
                    <i class='bx bx-user-plus'></i> @Localizer["AddNewParent"]
                </a>
            </div>
        }
    </div>

    <!-- Table Footer -->
    <div class="table-footer">
        <div class="table-info">
            @Html.Raw(string.Format(Localizer["ShowingParents"].Value,
            $"<strong><span id='visibleCount'>{totalParents}</span></strong>",
                        $"<strong>{totalParents}</strong>"))
        </div>
    </div>
</div>

@section scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/parent/search.js" asp-append-version="true"></script>
    <script src="~/js/confirmModal.js" asp-append-version="true"></script>
}