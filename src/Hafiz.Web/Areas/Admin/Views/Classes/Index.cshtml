@using Hafiz.Common.Helper
@using Hafiz.DTOs
@model IEnumerable<Hafiz.Models.Class>

@inject Microsoft.AspNetCore.Mvc.Localization.IViewLocalizer Localizer

@{
    ViewData["Title"] = Localizer["Title"];
}

<!-- Page Header -->
<div class="d-flex justify-between align-center mb-lg flex-wrap gap-md">
    <div>
        <h2 class="section-title mb-sm">
            <i class='bx bx-book' style="color: var(--primary-green);"></i>
            @Localizer["Title"]
        </h2>
        <p class="text-medium">@Localizer["PageDescription"]</p>
    </div>
    <div class="btn-group">
        <a asp-action="Create" class="btn btn-primary">
            <i class='bx bx-plus-circle'></i>
            <span>@Localizer["AddNewClass"]</span>
        </a>
        <button class="btn btn-outline" id="exportBtn">
            <i class='bx bx-download'></i>
            <span>@Localizer["Export"]</span>
        </button>
    </div>
</div>

<!-- Statistics Cards -->
@{
    var totalClasses = Model.Count();
    var maleClasses = Model.Count(c => c.Gender.ToString() == "male");
    var femaleClasses = Model.Count(c => c.Gender.ToString() == "female");
    var totalTeachers = Model.SelectMany(c => c.Teachers).Distinct().Count();
}

<div class="grid-auto-fit mb-lg">
    <div class="card card-stat">
        <div class="card-stat-icon">
            <i class='bx bx-book-open'></i>
        </div>
        <div class="card-stat-content">
            <div class="card-stat-label">@Localizer["TotalClasses"]</div>
            <div class="card-stat-value">@totalClasses</div>
        </div>
    </div>

    <div class="card card-stat" style="--icon-bg: var(--info);">
        <div class="card-stat-icon" style="background: var(--info);">
            <i class='bx bx-male'></i>
        </div>
        <div class="card-stat-content">
            <div class="card-stat-label">@Localizer["MaleClasses"]</div>
            <div class="card-stat-value">@maleClasses</div>
        </div>
    </div>

    <div class="card card-stat" style="--icon-bg: var(--warning);">
        <div class="card-stat-icon" style="background: var(--warning);">
            <i class='bx bx-female'></i>
        </div>
        <div class="card-stat-content">
            <div class="card-stat-label">@Localizer["FemaleClasses"]</div>
            <div class="card-stat-value">@femaleClasses</div>
        </div>
    </div>

    <div class="card card-stat" style="--icon-bg: var(--success);">
        <div class="card-stat-icon" style="background: var(--success);">
            <i class='bx bx-group'></i>
        </div>
        <div class="card-stat-content">
            <div class="card-stat-label">@Localizer["TotalTeachers"]</div>
            <div class="card-stat-value">@totalTeachers</div>
        </div>
    </div>
</div>

<!-- Table Container -->
<div class="table-container">

    <!-- Search and Filter Toolbar -->
    <div class="table-toolbar">
        <div class="table-search">
            <input type="text" id="searchInput" placeholder="@Localizer["SearchPlaceholder"]">
            <i class='bx bx-search'></i>
        </div>
        <div class="table-filters">
            <select id="genderFilter" class="form-select form-input-sm">
                <option value="">@Localizer["AllTypes"]</option>
                @{
                    var genders = Model.Select(c => c.Gender)
                    .Distinct()
                    .OrderBy(g => g);

                    foreach (var gender in genders)
                    {
                        <option value="@gender">@Localizer[$"Gender_{gender}"]</option>
                    }
                }
            </select>
            <button id="clearFilters" class="btn btn-outline btn-sm">
                <i class='bx bx-refresh'></i>
                <span class="d-none d-md-inline">@Localizer["Reset"]</span>
            </button>
        </div>
    </div>

    <!-- Records grid -->
    <div class="record-grid" id="classesGrid">
        @if (Model != null && Model.Any())
        {
            int index = 0;
            foreach (var cl in Model)
            {
                var teacherNames = string.Join("، ", cl.Teachers.Select(t => t.TeacherInfo.FirstName));
                var hasTeachers = cl.Teachers.Any();
                var days = string.Join("، ", cl.ClassDays.Select(d => Formatting.GetLocalizedDayName(d)));
                var avatarVariant = index % 5;
                var isFemale = cl.Gender.ToString().ToLower() == "female";
                var badgeVariant = isFemale ? "record-badge--green" : "record-badge--gold";

                <div class="record-card" data-name="@cl.Name.ToLower()" data-gender="@cl.Gender.ToString().ToLower()">

                    <div class="record-card-header">
                        <div class="record-avatar record-avatar--@avatarVariant">
                            @cl.Name.Substring(0, 1)
                        </div>
                        <div class="record-identity">
                            <span class="record-name">@cl.Name</span>
                            <span class="record-badge @badgeVariant">
                                <i class='bx @(isFemale ? "bx-female" : "bx-male")'></i>
                                <span>@Localizer[$"Gender_{cl.Gender}"]</span>
                            </span>
                        </div>
                    </div>

                    <div class="record-info">
                        <div class="record-info-row">
                            <i class='bx bx-chalkboard'></i>
                            @if (hasTeachers)
                            {
                                <span title="@teacherNames">@teacherNames</span>
                            }
                            else
                            {
                                <span>@Localizer["NoTeachers"]</span>
                            }
                        </div>
                        <div class="record-info-row">
                            <i class='bx bx-calendar'></i>
                            <span title="@days">@days</span>
                        </div>
                        <div class="record-info-row">
                            <i class='bx bx-time-five'></i>
                            <span class="record-info-value">@cl.ClassTime.ToString("hh:mm tt")</span>
                        </div>
                        <div class="record-info-row">
                            <i class='bx bx-group'></i>
                            <span class="record-info-value">@cl.Students.Count @Localizer["Students"]</span>
                        </div>
                    </div>

                    <div class="record-actions">
                        <a asp-action="Edit" asp-route-id="@cl.Id" class="record-btn record-btn-edit">
                            <i class='bx bx-edit'></i>
                            <span>@Localizer["Edit"]</span>
                        </a>
                        <form asp-action="Delete" asp-route-id="@cl.Id" method="post" class="delete-form">
                            <button type="submit" class="record-btn record-btn-delete"
                                    data-confirm-delete="@Localizer["DeleteConfirmation"] @cl.Name؟"
                                    data-tooltip="@Localizer["Delete"]">
                                <i class='bx bx-trash'></i>
                            </button>
                        </form>
                    </div>
                </div>
                index++;
            }
        }
        else
        {
            <div class="record-empty">
                <i class='bx bx-book'></i>
                <h3 class="record-empty-title">@Localizer["NoClasses"]</h3>
                <p class="text-medium">@Localizer["NoClassesDescription"]</p>
                <a asp-action="Create" class="btn btn-primary mt-md">
                    <i class='bx bx-plus-circle'></i> @Localizer["AddNewClass"]
                </a>
            </div>
        }
    </div>

    <!-- Table Footer -->
    <div class="table-footer">
        <div class="table-info">
            @Localizer["ShowingResults"] <strong><span id="visibleCount">@(Model?.Count() ?? 0)</span></strong>
            @Localizer["Of"]
            <strong>@(Model?.Count() ?? 0)</strong> @Localizer["Class"]
        </div>
    </div>
</div>

@section scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/classes/search.js" asp-append-version="true"></script>
    <script src="~/js/confirmModal.js" asp-append-version="true"></script>
}