@model Hafiz.DTOs.Reports.AdminDailyReportsViewModel
@using Hafiz.Models
@{
    ViewData["Title"] = "التقارير اليومية";

    // تسمية حالة الحضور بالعربية + لون البطاقة
    (string Label, string Css) StatusInfo(AttendanceStatus? status) => status switch
    {
        AttendanceStatus.Present => ("حاضر", "dr-present"),
        AttendanceStatus.Late => ("متأخر", "dr-late"),
        AttendanceStatus.Absent => ("غائب", "dr-absent"),
        AttendanceStatus.Excused => ("بعذر", "dr-excused"),
        _ => ("لم يُسجّل", "dr-pending"),
    };

    string WirdTypeLabel(AssignmentType type) => type switch
    {
        AssignmentType.Wird => "ورد",
        AssignmentType.Memorization => "حفظ",
        AssignmentType.Revision => "مراجعة",
        AssignmentType.Tajwid => "تجويد",
        AssignmentType.Tafsir => "تفسير",
        _ => "أخرى",
    };

    string WirdDescription(WirdAssignment w)
    {
        if (w.FromSurah != null || w.ToSurah != null)
        {
            var from = w.FromSurah != null ? $"{Hafiz.Common.Helper.Formatting.GetLocalizedSurahName(w.FromSurah.Value)}{(string.IsNullOrEmpty(w.FromAyah) ? "" : $" ({w.FromAyah})")}" : "";
            var to = w.ToSurah != null ? $"{Hafiz.Common.Helper.Formatting.GetLocalizedSurahName(w.ToSurah.Value)}{(w.ToAyah != null ? $" ({w.ToAyah})" : "")}" : "";
            if (!string.IsNullOrEmpty(from) && !string.IsNullOrEmpty(to))
                return $"من {from} إلى {to}";
            return !string.IsNullOrEmpty(from) ? from : to;
        }
        if (w.Amount != null)
        {
            var unit = w.AmountUnit switch
            {
                WirdUnit.Pages => "صفحة",
                WirdUnit.Ayahs => "آية",
                WirdUnit.Juz => "جزء",
                _ => "",
            };
            return $"{w.Amount:0.##} {unit}".Trim();
        }
        return "";
    }
}

<link rel="stylesheet" href="~/css/admin/daily-reports.css" asp-append-version="true" />

<div class="daily-reports">
    <!-- رأس الصفحة + اختيار التاريخ -->
    <div class="d-flex justify-between align-center mb-lg flex-wrap gap-md">
        <div>
            <h2 class="section-title mb-sm">
                <i class='bx bx-calendar-event' style="color: var(--primary-green);"></i>
                التقارير اليومية
            </h2>
            <p class="text-medium">حضور وغياب وأوراد الطلاب لكل شعبة في يوم @Model.Date.ToString("yyyy-MM-dd")</p>
        </div>
        <form method="get" asp-action="Daily" class="d-flex align-center gap-sm flex-wrap">
            <input type="date" name="date" value="@Model.Date.ToString("yyyy-MM-dd")"
                   class="form-input form-input-sm" onchange="this.form.submit()" />
            <a asp-action="Daily" asp-route-date="@DateTime.Today.ToString("yyyy-MM-dd")"
               class="btn btn-outline btn-sm">
                <i class='bx bx-calendar-check'></i> اليوم
            </a>
        </form>
    </div>

    <!-- ملخص المركز لهذا اليوم -->
    <div class="grid-auto-fit mb-lg" style="grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));">
        <div class="card card-stat">
            <div class="card-stat-icon" style="background: linear-gradient(135deg, #4a90d9, #2c6fad);">
                <i class='bx bx-group'></i>
            </div>
            <div class="card-stat-content">
                <div class="card-stat-label">إجمالي الطلاب</div>
                <div class="card-stat-value">@Model.TotalStudents</div>
            </div>
        </div>
        <div class="card card-stat">
            <div class="card-stat-icon" style="background: linear-gradient(135deg, #2e8b57, #1f6b41);">
                <i class='bx bx-check-circle'></i>
            </div>
            <div class="card-stat-content">
                <div class="card-stat-label">حاضر</div>
                <div class="card-stat-value">@Model.TotalPresent</div>
            </div>
        </div>
        <div class="card card-stat">
            <div class="card-stat-icon" style="background: linear-gradient(135deg, #ff9800, #e07b00);">
                <i class='bx bx-time-five'></i>
            </div>
            <div class="card-stat-content">
                <div class="card-stat-label">متأخر</div>
                <div class="card-stat-value">@Model.TotalLate</div>
            </div>
        </div>
        <div class="card card-stat">
            <div class="card-stat-icon" style="background: linear-gradient(135deg, #dc3545, #b02a37);">
                <i class='bx bx-x-circle'></i>
            </div>
            <div class="card-stat-content">
                <div class="card-stat-label">غائب</div>
                <div class="card-stat-value">@Model.TotalAbsent</div>
            </div>
        </div>
        <div class="card card-stat">
            <div class="card-stat-icon" style="background: linear-gradient(135deg, #17a2b8, #117a8b);">
                <i class='bx bx-note'></i>
            </div>
            <div class="card-stat-content">
                <div class="card-stat-label">بعذر</div>
                <div class="card-stat-value">@Model.TotalExcused</div>
            </div>
        </div>
        <div class="card card-stat">
            <div class="card-stat-icon" style="background: linear-gradient(135deg, #9c27b0, #7b1fa2);">
                <i class='bx bx-book-bookmark'></i>
            </div>
            <div class="card-stat-content">
                <div class="card-stat-label">الأوراد المسندة</div>
                <div class="card-stat-value">@Model.TotalWirds</div>
            </div>
        </div>
    </div>

    @if (!Model.Classes.Any())
    {
        <div class="card card-standard" style="padding: 3rem; text-align:center;">
            <i class='bx bx-folder-open' style="font-size:3rem; color: var(--text-muted, #999);"></i>
            <p class="text-medium mt-md">لا توجد شُعب لعرضها.</p>
        </div>
    }
    else
    {
        <!-- شريط أدوات: بحث + تصفية + توسيع/طي -->
        <div class="card card-standard mb-lg dr-toolbar">
            <div class="dr-toolbar-row">
                <div class="table-search dr-search">
                    <input type="text" id="drClassSearch" placeholder="ابحث عن شعبة بالاسم...">
                    <i class='bx bx-search'></i>
                </div>
                <select id="drStatusFilter" class="form-select form-input-sm">
                    <option value="">كل الحالات</option>
                    <option value="dr-absent">الغائبون فقط</option>
                    <option value="dr-late">المتأخرون فقط</option>
                    <option value="dr-pending">غير المسجّلين فقط</option>
                    <option value="dr-excused">أصحاب الأعذار فقط</option>
                    <option value="dr-present">الحاضرون فقط</option>
                </select>
                <div class="btn-group">
                    <button type="button" id="drExpandAll" class="btn btn-outline btn-sm">
                        <i class='bx bx-chevrons-down'></i> <span class="d-none d-md-inline">توسيع الكل</span>
                    </button>
                    <button type="button" id="drCollapseAll" class="btn btn-outline btn-sm">
                        <i class='bx bx-chevrons-up'></i> <span class="d-none d-md-inline">طي الكل</span>
                    </button>
                </div>
            </div>
            <p class="text-medium fs-sm mb-0" id="drNoMatch" style="display:none; padding-top:.5rem;">
                لا توجد نتائج مطابقة.
            </p>
        </div>
    }

    <!-- تقرير كل شعبة على حدة -->
    @foreach (var cls in Model.Classes)
    {
        <div class="card card-standard mb-lg dr-class-card" data-name="@cls.ClassName.ToLower()">
            <div class="card-header dr-class-header" role="button" tabindex="0" aria-expanded="false">
                <h3 class="card-title">
                    <i class='bx bx-chevron-left dr-toggle-icon'></i>
                    <i class='bx bx-group' style="color: var(--primary-green);"></i>
                    @cls.ClassName
                    <span class="dr-class-count">(@cls.Students.Count() طالب)</span>
                </h3>
                <div class="dr-class-badges">
                    <span class="dr-chip dr-present">حاضر @cls.PresentCount</span>
                    <span class="dr-chip dr-late">متأخر @cls.LateCount</span>
                    <span class="dr-chip dr-absent">غائب @cls.AbsentCount</span>
                    <span class="dr-chip dr-excused">بعذر @cls.ExcusedCount</span>
                    <span class="dr-chip dr-pending">لم يُسجّل @cls.PendingCount</span>
                    <span class="dr-chip dr-rate">نسبة الحضور @cls.AttendanceRate%</span>
                </div>
            </div>
            <div class="card-body dr-class-body">
                @if (!cls.Students.Any())
                {
                    <p class="text-medium" style="padding: 0.5rem 0;">لا يوجد طلاب في هذه الشعبة.</p>
                }
                else
                {
                    <div class="table-wrapper">
                        <table class="table table-responsive-cards">
                            <thead>
                                <tr>
                                    <th style="width: 40px;">#</th>
                                    <th>اسم الطالب</th>
                                    <th style="width: 130px;">الحالة</th>
                                    <th>الأوراد المسندة اليوم</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{ int idx = 1; }
                                @foreach (var st in cls.Students)
                                {
                                    var info = StatusInfo(st.Status);
                                    <tr class="dr-student-row" data-status="@info.Css">
                                        <td data-label="#">@idx</td>
                                        <td data-label="اسم الطالب" class="dr-card-name">
                                            <a asp-controller="Students" asp-action="Details" asp-route-id="@st.StudentId"
                                               class="fw-medium dr-student-link">@st.FullName</a>
                                        </td>
                                        <td data-label="الحالة">
                                            <span class="dr-status @info.Css">@info.Label</span>
                                        </td>
                                        <td data-label="الأوراد المسندة اليوم" class="dr-card-wirds">
                                            @if (st.Wirds.Any())
                                            {
                                                <div class="dr-wirds">
                                                    @foreach (var w in st.Wirds)
                                                    {
                                                        var desc = WirdDescription(w);
                                                        <span class="dr-wird @(w.IsCompleted ? "dr-wird-done" : "") @(w.IsUpcoming ? "dr-wird-upcoming" : "")"
                                                              title="@(w.IsUpcoming ? "ورد قادم" : w.IsCompleted ? "مكتمل" : "قيد التنفيذ")">
                                                            @if (w.IsUpcoming)
                                                            {
                                                                <i class='bx bx-calendar-star'></i>
                                                            }
                                                            <strong>@WirdTypeLabel(w.Type)</strong>@(string.IsNullOrEmpty(desc) ? "" : $": {desc}")
                                                            @if (w.IsCompleted)
                                                            {
                                                                <i class='bx bx-check'></i>
                                                            }
                                                        </span>
                                                    }
                                                </div>
                                            }
                                            else
                                            {
                                                <span class="text-medium">—</span>
                                            }
                                        </td>
                                    </tr>
                                    idx++;
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    }
</div>

@section Scripts {
    <script src="~/js/admin-daily-reports.js" asp-append-version="true"></script>
}
