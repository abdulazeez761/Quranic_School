@model IEnumerable<Hafiz.Models.Teacher>
@inject Microsoft.AspNetCore.Mvc.Localization.IViewLocalizer Localizer

@{
    ViewData["Title"] = @Localizer["Title"];
}

<!-- Page Header -->
<div class="d-flex justify-between align-center mb-lg flex-wrap gap-md">
    <div>
        <h2 class="section-title mb-sm">
            <i class='bx bx-chalkboard' style="color: var(--primary-green);"></i>
            @Localizer["Teachers_Management"]
        </h2>
        <p class="text-medium">@Localizer["Show_Manage"]</p>
    </div>
    <div class="btn-group">
        <a asp-action="Create" class="btn btn-primary">
            <i class='bx bx-plus'></i>
            <span>@Localizer["Add"]</span>
        </a>
        <button class="btn btn-outline" id="exportBtn">
            <i class='bx bx-download'></i>
            <span>@Localizer["Export"]</span>
        </button>
    </div>
</div>

<!-- Statistics Cards -->
@{
    var totalTeachers = Model.Count();
    var totalClasses = Model.SelectMany(t => t.Classes).Select(c => c.Id).Distinct().Count();
    var teachersWithClasses = Model.Count(t => t.Classes.Any());
    var teachersWithoutClasses = totalTeachers - teachersWithClasses;
}

<div class="grid-4 mb-lg">
    <div class="card card-stat">
        <div class="card-stat-icon">
            <i class='bx bx-user'></i>
        </div>
        <div class="card-stat-content">
            <div class="card-stat-label">@Localizer["Total_Teachers"]</div>
            <div class="card-stat-value">@totalTeachers</div>
        </div>
    </div>

    <div class="card card-stat">
        <div class="card-stat-icon" style="background: var(--success);">
            <i class='bx bx-check-circle'></i>
        </div>
        <div class="card-stat-content">
            <div class="card-stat-label">@Localizer["Has_Sessions"]</div>
            <div class="card-stat-value">@teachersWithClasses</div>
        </div>
    </div>

    <div class="card card-stat">
        <div class="card-stat-icon" style="background: var(--warning);">
            <i class='bx bx-error'></i>
        </div>
        <div class="card-stat-content">
            <div class="card-stat-label">@Localizer["Without_sessions"]</div>
            <div class="card-stat-value">@teachersWithoutClasses</div>
        </div>
    </div>

    <div class="card card-stat">
        <div class="card-stat-icon" style="background: var(--info);">
            <i class='bx bx-group'></i>
        </div>
        <div class="card-stat-content">
            <div class="card-stat-label">@Localizer["Number_Sessions"]</div>
            <div class="card-stat-value">@totalClasses</div>
        </div>
    </div>
</div>

<!-- Teachers Table -->
<div class="table-container">
    <!-- Search and Filter Toolbar -->
    <div class="table-toolbar">
        <div class="table-search">
            <input type="text" id="searchInput" placeholder="@Localizer["Using_first_Second_Name"]">
            <i class='bx bx-search'></i>
        </div>
        <div class="table-filters">
            <select class="form-select form-input-sm" id="classFilter">
                <option value="">@Localizer["All_Sessions"]</option>
                @{
                    var allClasses = Model.SelectMany(s => s.Classes)
                    .Select(c => c.Name)
                    .Distinct()
                    .OrderBy(name => name);

                    foreach (var className in allClasses)
                    {
                        <option value="@className">@className</option>
                    }
                }
            </select>
            <button id="clearFilters" class="btn btn-outline btn-sm">
                <i class='bx bx-refresh'></i>
                <span class="d-none d-md-inline">@Localizer["Reset"]</span>
            </button>
        </div>
    </div>

    <!-- Records grid -->
    <div class="record-grid" id="teachersGrid">
        @if (Model != null && Model.Any())
        {
            int index = 0;
            foreach (var teacher in Model)
            {
                var classesData = string.Join(",", teacher.Classes.Select(c => c.Name));
                var hasClasses = teacher.Classes.Any();
                var firstClass = teacher.Classes.Select(c => c.Name).FirstOrDefault();
                var avatarVariant = index % 5;
                var badgeVariant = index % 2 == 0 ? "record-badge--green" : "record-badge--gold";

                <div class="record-card" data-firstname="@teacher.TeacherInfo.FirstName.ToLower()"
                     data-secondname="@teacher.TeacherInfo.SecondName.ToLower()" data-classes="@classesData">

                    <div class="record-card-header">
                        <div class="record-avatar record-avatar--@avatarVariant">
                            @teacher.TeacherInfo.FirstName.Substring(0, 1)
                        </div>
                        <div class="record-identity">
                            <span class="record-name">@teacher.TeacherInfo.FirstName @teacher.TeacherInfo.SecondName</span>
                            @if (hasClasses)
                            {
                                <span class="record-badge @badgeVariant" title="@string.Join(", ", teacher.Classes.Select(c => c.Name))">
                                    <i class='bx bx-book'></i>
                                    <span>@firstClass</span>
                                </span>
                            }
                            else
                            {
                                <span class="record-badge record-badge--empty">
                                    <i class='bx bx-info-circle'></i>
                                    <span>@Localizer["NO_Sesstions"]</span>
                                </span>
                            }
                        </div>
                    </div>

                    <div class="record-info">
                        <div class="record-info-row">
                            <i class='bx bx-user'></i>
                            <span class="record-info-value" title="@teacher.TeacherInfo.Username">@teacher.TeacherInfo.Username</span>
                        </div>
                        <div class="record-info-row">
                            <i class='bx bx-phone'></i>
                            <span class="record-info-value">@teacher.TeacherInfo.PhoneNumber</span>
                        </div>
                    </div>

                    <div class="record-actions">
                        <a asp-action="Edit" asp-route-id="@teacher.UserId" class="record-btn record-btn-edit">
                            <i class='bx bx-edit'></i>
                            <span>@Localizer["Edit"]</span>
                        </a>
                        <form method="post" asp-action="Delete" asp-route-id="@teacher.UserId" class="delete-form">
                            <button type="submit" class="record-btn record-btn-delete"
                                    data-confirm-delete="@Localizer["Delete_confirm"] @teacher.TeacherInfo.FirstName @teacher.TeacherInfo.SecondName؟"
                                    data-tooltip="@Localizer["Delete"]">
                                <i class='bx bx-trash'></i>
                            </button>
                        </form>
                    </div>
                </div>
                index++;
            }
        }
        else
        {
            <div class="record-empty">
                <i class='bx bx-user-x'></i>
                <h3 class="record-empty-title">@Localizer["No_Data"]</h3>
                <p class="text-medium">@Localizer["Not_Added_yet"]</p>
                <a asp-action="Create" class="btn btn-primary mt-md">
                    <i class='bx bx-plus'></i> @Localizer["Add"]
                </a>
            </div>
        }
    </div>

    <!-- Table Footer with Pagination -->
    <div class="table-footer">
        <div class="table-info">
            @Localizer["show"] <strong><span id="visibleCount">@totalTeachers</span></strong> @Localizer["outOf"]
            <strong>@totalTeachers</strong> @Localizer["teaher"]
        </div>
        <!-- Optional: Add pagination here if needed -->
    </div>
</div>




@section scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script src="~/js/teacher/search.js"></script>
    <script src="~/js/confirmModal.js"></script>


}