@model Hafiz.DTOs.Student.StudentReportRow
@using Hafiz.Common.Helper
@using Hafiz.Web.Helpers
@{
    var Localizer = (Microsoft.AspNetCore.Mvc.Localization.IViewLocalizer)ViewData["Localizer"]!;

    var memPercent = Math.Min(
        100,
        Math.Round((double)Model.TotalMemorizedPages / WirdPageCalculator.TotalQuranPages * 100)
    );
    var extraPages = Model.TotalMemorizedPages - (Model.MemorizedJuz * WirdPageCalculator.PagesPerJuz);
    var initials = StudentReportViewHelpers.GetInitials(Model.FullName);
    var attClass = StudentReportViewHelpers.AttendanceClass(Model.AttendanceRate);
    var isConnected = !Model.IsInactiveWarning;

    var chipClass = isConnected ? "status-connected" : "status-disconnected";
    var chipText = isConnected
        ? (Model.LastWirdDate?.ToString("yyyy-MM-dd") ?? Localizer["LastActive"].Value)
        : Localizer["InactiveWarning"].Value;

    var lastWirdText = Model.LastWirdDate.HasValue
        ? $"{Localizer["LastWird"].Value}: {Model.LastWirdDate.Value:yyyy-MM-dd}"
        : Localizer["NoCompletedWirds"].Value;
}

<div class="report-row-mobile" data-accordion-item>
    <button type="button" class="row-mobile-summary" data-accordion-toggle aria-expanded="false">
        <div class="mobile-avatar-name">
            <div class="avatar-wrap">
                <div class="avatar-circle">@initials</div>
                @if (Model.UnreadNotesCount > 0)
                {
                    <span class="avatar-notes-badge" title="@Localizer["UnreadNotes"]">@Model.UnreadNotesCount</span>
                }
            </div>
            <div class="student-info">
                <span class="student-name">
                    @Model.FullName
                    @if (Model.IsHafiz)
                    {
                        <i class='bx bxs-award hafiz-badge' style="color:#ff9800;" title="@Localizer["Hafiz"]"></i>
                    }
                </span>
                <div class="status-chip-container-mobile">
                    <span class="status-chip @chipClass">
                        <span class="status-dot"></span>
                        <span>@chipText</span>
                    </span>
                </div>
            </div>
        </div>
        <div class="row-mobile-summary-side">
            <div class="status-chip-container-desktop">
                <span class="status-chip @chipClass">
                    <span class="status-dot"></span>
                    <span>@chipText</span>
                </span>
            </div>
            <i class='bx bx-chevron-down row-mobile-chevron'></i>
        </div>
    </button>

    <div class="row-mobile-progress">
        <div class="progress-info">
            <span class="progress-label">
                <i class='bx bx-book-open'></i>
                <span>@Localizer["MemorizedJuz"]</span>
            </span>
            <div class="progress-values">
                <span class="progress-fraction">@Model.MemorizedJuz/30</span>
                @if (extraPages > 0)
                {
                    <span class="progress-extra-pages">+ @((int)extraPages) @Localizer["PagesShort"]</span>
                }
            </div>
        </div>
        <div class="progress-bar-track">
            <div class="progress-bar-fill" style="width: @memPercent%"></div>
        </div>
    </div>

    <div class="row-mobile-details" data-accordion-panel>
        <div class="row-mobile-details-inner">
            <div class="row-mobile-class">
                <i class='bx bx-book'></i>
                <span>@(string.IsNullOrEmpty(Model.ClassName) ? Localizer["NoClass"].Value : Model.ClassName)</span>
            </div>

            <div class="row-mobile-stats">
                <div class="mobile-stat-item reviewed">
                    <span class="stat-value">
                        @((Model.ReviewedPages / WirdPageCalculator.PagesPerJuz).ToString("0.##"))
                    </span>
                    <span class="stat-label">@Localizer["JuzShort"] @Localizer["ReviewedPagesShort"]</span>
                </div>
                <div class="mobile-stat-item memorized">
                    <span class="stat-value">@Model.TotalMemorizedPages.ToString("0.##")</span>
                    <span class="stat-label">@Localizer["MemorizedPagesShort"]</span>
                </div>
                <div class="mobile-stat-item attendance att-@attClass">
                    <span class="stat-value">@Model.AttendanceRate%</span>
                    <span class="stat-label">@Localizer["AttendanceShort"]</span>
                </div>
            </div>

            <div class="row-mobile-wirds">
                <span class="wird-stat wird-total">
                    <i class='bx bx-list-check'></i>
                    <span class="wird-stat-value">@Model.TotalWirds</span>
                    <span class="wird-stat-label">@Localizer["TotalWirds"]</span>
                </span>
                <span class="wird-stat wird-completed">
                    <i class='bx bx-check-circle'></i>
                    <span class="wird-stat-value">@Model.CompletedWirds</span>
                    <span class="wird-stat-label">@Localizer["CompletedWirds"]</span>
                </span>
                <span class="wird-stat wird-pending">
                    <i class='bx bx-time'></i>
                    <span class="wird-stat-value">@(Model.TotalWirds - Model.CompletedWirds)</span>
                    <span class="wird-stat-label">@Localizer["PendingWirds"]</span>
                </span>
            </div>

            <div class="row-mobile-footer">
                <span class="last-active @(Model.IsInactiveWarning ? "warning" : "")">
                    <i class='bx bx-time-five'></i>
                    <span>@lastWirdText</span>
                </span>
            </div>

            @if (Model.UnreadNotesCount > 0)
            {
                <div class="row-mobile-notes-alert">
                    <i class='bx bxs-bell'></i>
                    <span>@Model.UnreadNotesCount @Localizer["UnreadNotes"]</span>
                </div>
            }

            <a asp-action="Details" asp-route-id="@Model.StudentId" class="row-mobile-details-link">
                <i class='bx bx-user-circle'></i>
                <span>@Localizer["ViewDetails"]</span>
            </a>
        </div>
    </div>
</div>
