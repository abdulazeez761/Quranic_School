@model Hafiz.DTOs.Student.AdminStudentDetailsViewModel
@using Hafiz.Common.Helper
@using Hafiz.Models
@inject Microsoft.AspNetCore.Mvc.Localization.IViewLocalizer Localizer

@{
    ViewData["Title"] = Localizer["StudentDetails"];
    var student = Model.Student;
    var attendance = Model.Attendance;
    var paginatedWirds = Model.PaginatedWirds;
    var parentNotes = Model.ParentNotes;

    var totalMemorizedPages = WirdPageCalculator.TotalMemorizedPages(student);
    var (memorizedJuzDisplay, memorizedPagesRemainder) = WirdPageCalculator.SplitJuzAndPages(totalMemorizedPages);
    var reviewedPages = student.ReviewedPages;
    var (reviewedJuzDisplay, reviewedPagesRemainder) = WirdPageCalculator.SplitJuzAndPages(reviewedPages);
    var isHafiz = WirdPageCalculator.IsHafiz(student);
    var activeTab = Model.ActiveTab;
}

<div class="admin-student-details">
    <!-- Header -->
    <div class="student-detail-header">
        <div class="student-detail-avatar">
            <i class='bx bx-user'></i>
        </div>
        <div class="student-detail-info">
            <h1 class="student-detail-name">
                @student.StudentInfo.FirstName @student.StudentInfo.SecondName
                @if (isHafiz)
                {
                    <span class="hafiz-badge" title="@Localizer["HafizTitle"]">
                        <i class='bx bxs-award'></i> @Localizer["Hafiz"]
                    </span>
                }
            </h1>
            <p class="student-detail-username">@@@student.StudentInfo.Username</p>
            <p class="student-detail-class">
                <i class='bx bx-book'></i>
                @if (student.Classes?.Any() == true)
                {
                    @string.Join(", ", student.Classes.Select(c => c.Name))
                }
                else
                {
                    @Localizer["NoClass"]
                }
            </p>
        </div>
        <div class="header-actions">
            <a asp-area="Admin" asp-controller="Students" asp-action="Index" class="back-btn">
                <i class='bx bx-arrow-back'></i>
                @Localizer["BackToList"]
            </a>
        </div>
    </div>

    <!-- Tabs -->
    <div class="tabs-container">
        <div class="tabs-header">
            <button class="tab-btn @(activeTab == "overview" ? "active" : "")" onclick="openTab(event, 'overview')">
                <i class='bx bx-grid-alt'></i> @Localizer["Overview"]
            </button>
            <button class="tab-btn @(activeTab == "personal" ? "active" : "")" onclick="openTab(event, 'personal')">
                <i class='bx bx-info-circle'></i> @Localizer["PersonalInformation"]
            </button>
            <button class="tab-btn @(activeTab == "attendance" ? "active" : "")" onclick="openTab(event, 'attendance')">
                <i class='bx bx-calendar'></i> @Localizer["AttendanceHistory"]
            </button>
            <button class="tab-btn @(activeTab == "wirds" ? "active" : "")" onclick="openTab(event, 'wirds')">
                <i class='bx bx-book-bookmark'></i> @Localizer["WirdAssignments"]
            </button>
            <button class="tab-btn @(activeTab == "notes" ? "active" : "")" onclick="openTab(event, 'notes')">
                <i class='bx bx-note'></i> @Localizer["Notes"]
                @if (parentNotes.Any())
                {
                    <span class="tab-badge">@parentNotes.Count()</span>
                }
            </button>
        </div>

        <!-- Overview Tab -->
        <div id="overview" class="tab-content @(activeTab == "overview" ? "active" : "")">
            <div class="overview-cards">
                <div class="overview-card">
                    <div class="card-icon attendance-icon">
                        <i class='bx bx-calendar-check'></i>
                    </div>
                    <div class="card-content">
                        <h3>@Model.AttendanceRate%</h3>
                        <p>@Localizer["AttendanceRate"]</p>
                    </div>
                </div>
                <div class="overview-card">
                    <div class="card-icon completion-icon">
                        <i class='bx bx-task'></i>
                    </div>
                    <div class="card-content">
                        <h3>@paginatedWirds.CompletedCount</h3>
                        <p>@Localizer["CompletedWirds"]</p>
                    </div>
                </div>
                <div class="overview-card">
                    <div class="card-icon juz-icon">
                        <i class='bx bx-book-open'></i>
                    </div>
                    <div class="card-content">
                        <h3>@memorizedJuzDisplay<span class="card-total">/30</span></h3>
                        <p>@Localizer["MemorizedJuz"]</p>
                    </div>
                </div>
                <div class="overview-card">
                    <div class="card-icon tajwid-icon">
                        <i class='bx bx-star'></i>
                    </div>
                    <div class="card-content">
                        <h3>@Localizer[$"TajwidLevel_{student.TajwidLevel}"]</h3>
                        <p>@Localizer["TajwidLevel"]</p>
                    </div>
                </div>
            </div>

            <!-- Memorization & Review -->
            <div class="overview-cards">
                <div class="overview-card">
                    <div class="card-icon" style="background: rgba(46,139,87,0.15); color: #2e8b57;">
                        <i class='bx bx-bookmark-heart'></i>
                    </div>
                    <div class="card-content">
                        <h3>@totalMemorizedPages.ToString("0.##")</h3>
                        <p>
                            @Localizer["MemorizedPages"]
                            <small style="display:block; opacity:0.75;">
                                @memorizedJuzDisplay @Localizer["JuzShort"]
                                @if (memorizedPagesRemainder > 0)
                                {
                                    <text>+ @memorizedPagesRemainder.ToString("0.##") @Localizer["UnitPages"]</text>
                                }
                            </small>
                        </p>
                    </div>
                </div>
                <div class="overview-card">
                    <div class="card-icon" style="background: rgba(59,130,246,0.15); color: #3b82f6;">
                        <i class='bx bx-revision'></i>
                    </div>
                    <div class="card-content">
                        <h3>@reviewedPages.ToString("0.##")</h3>
                        <p>
                            @Localizer["ReviewedPages"]
                            <small style="display:block; opacity:0.75;">
                                @reviewedJuzDisplay @Localizer["JuzShort"]
                                @if (reviewedPagesRemainder > 0)
                                {
                                    <text>+ @reviewedPagesRemainder.ToString("0.##") @Localizer["UnitPages"]</text>
                                }
                            </small>
                        </p>
                    </div>
                </div>
                <div class="overview-card">
                    <div class="card-icon" style="background: rgba(139,92,246,0.15); color: #8b5cf6;">
                        <i class='bx bx-collection'></i>
                    </div>
                    <div class="card-content">
                        <h3>@reviewedJuzDisplay</h3>
                        <p>@Localizer["ReviewedJuz"]</p>
                    </div>
                </div>
            </div>

            <!-- Attendance Summary -->
            @if (attendance.Count > 0)
            {
                var totalAtt = attendance.Count;
                <div class="section-card attendance-summary-card">
                    <div class="section-header">
                        <h2><i class='bx bx-pie-chart-alt-2'></i> @Localizer["AttendanceSummary"]</h2>
                    </div>
                    <div class="section-content">
                        <div class="attendance-bar-chart">
                            <div class="att-bar-row">
                                <span class="att-bar-label">@Localizer["AttendanceStatus_Present"]</span>
                                <div class="att-bar-track">
                                    <div class="att-bar-fill att-present" style="width: @(totalAtt > 0 ? Math.Round((double)Model.PresentCount / totalAtt * 100) : 0)%"></div>
                                </div>
                                <span class="att-bar-count">@Model.PresentCount</span>
                            </div>
                            <div class="att-bar-row">
                                <span class="att-bar-label">@Localizer["AttendanceStatus_Late"]</span>
                                <div class="att-bar-track">
                                    <div class="att-bar-fill att-late" style="width: @(totalAtt > 0 ? Math.Round((double)Model.LateCount / totalAtt * 100) : 0)%"></div>
                                </div>
                                <span class="att-bar-count">@Model.LateCount</span>
                            </div>
                            <div class="att-bar-row">
                                <span class="att-bar-label">@Localizer["AttendanceStatus_Absent"]</span>
                                <div class="att-bar-track">
                                    <div class="att-bar-fill att-absent" style="width: @(totalAtt > 0 ? Math.Round((double)Model.AbsentCount / totalAtt * 100) : 0)%"></div>
                                </div>
                                <span class="att-bar-count">@Model.AbsentCount</span>
                            </div>
                            <div class="att-bar-row">
                                <span class="att-bar-label">@Localizer["AttendanceStatus_Excused"]</span>
                                <div class="att-bar-track">
                                    <div class="att-bar-fill att-excused" style="width: @(totalAtt > 0 ? Math.Round((double)Model.ExcusedCount / totalAtt * 100) : 0)%"></div>
                                </div>
                                <span class="att-bar-count">@Model.ExcusedCount</span>
                            </div>
                        </div>
                        <div class="att-total-label">
                            @Localizer["TotalRecords"]: <strong>@totalAtt</strong>
                        </div>
                    </div>
                </div>
            }

            <!-- Memorization Progress Circle -->
            <div class="section-card">
                <div class="section-header">
                    <h2><i class='bx bx-book-open'></i> @Localizer["MemorizationProgress"]</h2>
                </div>
                <div class="section-content">
                    <div class="memorization-progress">
                        <div class="progress-circle-container">
                            <div class="progress-circle" style="--progress: @(Math.Min(100, Math.Round((double)totalMemorizedPages / WirdPageCalculator.TotalQuranPages * 100)))">
                                <span class="progress-circle-value">@memorizedJuzDisplay/30</span>
                                <span class="progress-circle-label">@Localizer["Juz"]</span>
                            </div>
                        </div>
                        <div class="progress-details">
                            <div class="progress-detail-item">
                                <i class='bx bx-check-circle'></i>
                                <span>@memorizedJuzDisplay @Localizer["JuzMemorized"]</span>
                            </div>
                            @if (memorizedPagesRemainder > 0)
                            {
                                <div class="progress-detail-item">
                                    <i class='bx bx-plus-circle'></i>
                                    <span>+ @memorizedPagesRemainder.ToString("0.##") @Localizer["UnitPages"]</span>
                                </div>
                            }
                            <div class="progress-detail-item">
                                <i class='bx bx-loader-circle'></i>
                                <span>@(Math.Max(0, 30 - memorizedJuzDisplay)) @Localizer["JuzRemaining"]</span>
                            </div>
                            <div class="progress-detail-item">
                                <i class='bx bx-revision'></i>
                                <span>@reviewedPages.ToString("0.##") @Localizer["PagesReviewed"]</span>
                            </div>
                            <div class="progress-detail-item">
                                <i class='bx bx-collection'></i>
                                <span>@reviewedJuzDisplay @Localizer["JuzReviewed"]</span>
                            </div>
                            <div class="progress-detail-item">
                                <i class='bx bx-star'></i>
                                <span>@Localizer["TajwidLevel"]: @Localizer[$"TajwidLevel_{student.TajwidLevel}"]</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Personal Info Tab -->
        <div id="personal" class="tab-content @(activeTab == "personal" ? "active" : "")">
            <div class="section-card">
                <div class="section-header">
                    <h2><i class='bx bx-info-circle'></i> @Localizer["PersonalInformation"]</h2>
                </div>
                <div class="section-content">
                    <div class="info-grid">
                        <div class="info-item">
                            <label><i class='bx bx-envelope'></i> @Localizer["Email"]</label>
                            <span>@(string.IsNullOrEmpty(student.StudentInfo.Email) ? Localizer["NotProvided"].Value : student.StudentInfo.Email)</span>
                        </div>
                        <div class="info-item">
                            <label><i class='bx bx-phone'></i> @Localizer["PhoneNumber"]</label>
                            <span>@(string.IsNullOrEmpty(student.StudentInfo.PhoneNumber) ? Localizer["NotProvided"].Value : student.StudentInfo.PhoneNumber)</span>
                        </div>
                        <div class="info-item">
                            <label><i class='bx bx-calendar'></i> @Localizer["DateOfBirth"]</label>
                            <span>@student.DateOfBirth.ToString("yyyy-MM-dd")</span>
                        </div>
                        <div class="info-item">
                            <label><i class='bx bx-user'></i> @Localizer["Gender"]</label>
                            <span>@Localizer[$"Gender_{student.sex}"]</span>
                        </div>
                        <div class="info-item">
                            <label><i class='bx bx-group'></i> @Localizer["Parent"]</label>
                            <span>
                                @if (student.Parent != null)
                                {
                                    @($"{student.Parent.ParentInfo.FirstName} {student.Parent.ParentInfo.SecondName}")
                                }
                                else
                                {
                                    @Localizer["NotProvided"]
                                }
                            </span>
                        </div>
                        <div class="info-item">
                            <label><i class='bx bx-book'></i> @Localizer["ClassesEnrolled"]</label>
                            <span>
                                @if (student.Classes?.Any() == true)
                                {
                                    @string.Join(", ", student.Classes.Select(c => c.Name))
                                }
                                else
                                {
                                    @Localizer["NoClass"]
                                }
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Attendance Tab -->
        <div id="attendance" class="tab-content @(activeTab == "attendance" ? "active" : "")">
            <div class="section-card">
                <div class="section-header">
                    <h2><i class='bx bx-calendar'></i> @Localizer["AttendanceHistory"]</h2>
                    @if (attendance.Count > 0)
                    {
                        <span class="header-badge badge-green">@Model.AttendanceRate% @Localizer["AttendanceRate"]</span>
                    }
                </div>
                <div class="section-content">
                    <!-- Date Filter -->
                    <form method="get" class="filter-form mb-lg">
                        <input type="hidden" name="id" value="@student.UserId" />
                        <input type="hidden" name="tab" value="attendance" />
                        <div class="filter-row">
                            <div class="filter-group">
                                <label>@Localizer["FromDate"]</label>
                                <input type="date" name="fromDate" value="@Model.AttendanceFromDate?.ToString("yyyy-MM-dd")" class="form-input" />
                            </div>
                            <div class="filter-group">
                                <label>@Localizer["ToDate"]</label>
                                <input type="date" name="toDate" value="@Model.AttendanceToDate?.ToString("yyyy-MM-dd")" class="form-input" />
                            </div>
                            <div class="filter-actions">
                                <button type="submit" class="btn btn-primary btn-sm">
                                    <i class='bx bx-filter'></i> @Localizer["Filter"]
                                </button>
                                <a asp-action="Details" asp-route-id="@student.UserId" asp-route-tab="attendance" class="btn btn-outline btn-sm">
                                    <i class='bx bx-reset'></i> @Localizer["Clear"]
                                </a>
                            </div>
                        </div>
                    </form>

                    <!-- Attendance Stats -->
                    @if (attendance.Count > 0)
                    {
                        <div class="att-stats-grid mb-lg">
                            <div class="att-stat-card att-stat-present">
                                <span class="att-stat-count">@Model.PresentCount</span>
                                <span class="att-stat-label">@Localizer["AttendanceStatus_Present"]</span>
                            </div>
                            <div class="att-stat-card att-stat-late">
                                <span class="att-stat-count">@Model.LateCount</span>
                                <span class="att-stat-label">@Localizer["AttendanceStatus_Late"]</span>
                            </div>
                            <div class="att-stat-card att-stat-absent">
                                <span class="att-stat-count">@Model.AbsentCount</span>
                                <span class="att-stat-label">@Localizer["AttendanceStatus_Absent"]</span>
                            </div>
                            <div class="att-stat-card att-stat-excused">
                                <span class="att-stat-count">@Model.ExcusedCount</span>
                                <span class="att-stat-label">@Localizer["AttendanceStatus_Excused"]</span>
                            </div>
                        </div>
                    }

                    @if (attendance.Any())
                    {
                        <div class="table-responsive">
                            <table class="attendance-table">
                                <thead>
                                    <tr>
                                        <th>@Localizer["Date"]</th>
                                        <th>@Localizer["Class"]</th>
                                        <th>@Localizer["Status"]</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var record in attendance.OrderByDescending(a => a.Date))
                                    {
                                        <tr>
                                            <td>
                                                <div class="date-cell">
                                                    <i class='bx bx-calendar'></i>
                                                    @record.Date.ToString("yyyy-MM-dd")
                                                </div>
                                            </td>
                                            <td>@record.Class?.Name</td>
                                            <td>
                                                <span class="status-badge status-@record.Status.ToString().ToLower()">
                                                    @Localizer[$"AttendanceStatus_{record.Status}"]
                                                </span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="no-data">
                            <i class='bx bx-calendar-x'></i>
                            <p>@Localizer["NoAttendanceRecords"]</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Wirds Tab -->
        <div id="wirds" class="tab-content @(activeTab == "wirds" ? "active" : "")">
            <div class="section-card">
                <div class="section-header">
                    <h2><i class='bx bx-book-bookmark'></i> @Localizer["WirdAssignments"]</h2>
                    <div class="wird-stats-badges">
                        <span class="header-badge badge-green">@paginatedWirds.CompletedCount @Localizer["Completed"]</span>
                        <span class="header-badge badge-orange">@paginatedWirds.PendingCount @Localizer["Pending"]</span>
                    </div>
                </div>
                <div class="section-content">
                    <!-- Filters -->
                    <div class="wird-filters mb-lg">
                        <div class="filter-tabs">
                            <a asp-action="Details" asp-route-id="@student.UserId" asp-route-tab="wirds"
                               class="filter-tab @(string.IsNullOrEmpty(Model.WirdStatus) ? "active" : "")">
                                @Localizer["All"]
                            </a>
                            <a asp-action="Details" asp-route-id="@student.UserId" asp-route-tab="wirds" asp-route-status="pending"
                               asp-route-type="@Model.WirdType"
                               class="filter-tab @(Model.WirdStatus == "pending" ? "active" : "")">
                                @Localizer["Pending"]
                            </a>
                            <a asp-action="Details" asp-route-id="@student.UserId" asp-route-tab="wirds" asp-route-status="completed"
                               asp-route-type="@Model.WirdType"
                               class="filter-tab @(Model.WirdStatus == "completed" ? "active" : "")">
                                @Localizer["Completed"]
                            </a>
                        </div>
                        <div class="filter-tabs">
                            <a asp-action="Details" asp-route-id="@student.UserId" asp-route-tab="wirds"
                               asp-route-status="@Model.WirdStatus"
                               class="filter-tab @(string.IsNullOrEmpty(Model.WirdType) ? "active" : "")">
                                @Localizer["AllTypes"]
                            </a>
                            <a asp-action="Details" asp-route-id="@student.UserId" asp-route-tab="wirds"
                               asp-route-status="@Model.WirdStatus" asp-route-type="Memorization"
                               class="filter-tab @(Model.WirdType == "Memorization" ? "active" : "")">
                                @Localizer["AssignmentType_Memorization"]
                            </a>
                            <a asp-action="Details" asp-route-id="@student.UserId" asp-route-tab="wirds"
                               asp-route-status="@Model.WirdStatus" asp-route-type="Revision"
                               class="filter-tab @(Model.WirdType == "Revision" ? "active" : "")">
                                @Localizer["AssignmentType_Revision"]
                            </a>
                            <a asp-action="Details" asp-route-id="@student.UserId" asp-route-tab="wirds"
                               asp-route-status="@Model.WirdStatus" asp-route-type="Tajwid"
                               class="filter-tab @(Model.WirdType == "Tajwid" ? "active" : "")">
                                @Localizer["AssignmentType_Tajwid"]
                            </a>
                            <a asp-action="Details" asp-route-id="@student.UserId" asp-route-tab="wirds"
                               asp-route-status="@Model.WirdStatus" asp-route-type="Tafsir"
                               class="filter-tab @(Model.WirdType == "Tafsir" ? "active" : "")">
                                @Localizer["AssignmentType_Tafsir"]
                            </a>
                        </div>
                    </div>

                    @if (paginatedWirds.Wirds.Any())
                    {
                        <div class="wirds-list">
                            @foreach (var wird in paginatedWirds.Wirds)
                            {
                                <div class="wird-item @(wird.IsCompleted ? "completed" : "")">
                                    <div class="wird-header">
                                        <div class="wird-type">
                                            <i class='bx bx-file'></i>
                                            @Localizer[$"AssignmentType_{wird.Type}"]
                                        </div>
                                        <div class="wird-date">
                                            <i class='bx bx-calendar'></i>
                                            @wird.AssignedDate.ToString("yyyy-MM-dd")
                                        </div>
                                    </div>
                                    <div class="wird-content">
                                        <div class="wird-range">
                                            <span class="range-label">@Localizer["From"]:</span>
                                            <span class="range-value">
                                                @Localizer[$"Surah_{wird.FromSurah}"] (@wird.FromAyah)
                                                - @Localizer["Page"] @wird.FromPage
                                            </span>
                                        </div>
                                        <div class="wird-range">
                                            <span class="range-label">@Localizer["To"]:</span>
                                            <span class="range-value">
                                                @Localizer[$"Surah_{wird.ToSurah}"] (@wird.ToAyah)
                                                - @Localizer["Page"] @wird.ToPage
                                            </span>
                                        </div>
                                        @if (!string.IsNullOrEmpty(wird.Note))
                                        {
                                            <div class="wird-note">
                                                <i class='bx bx-note'></i>
                                                <span>@wird.Note</span>
                                            </div>
                                        }
                                    </div>
                                    <div class="wird-footer">
                                        <span class="status-badge status-@wird.Status.ToString().ToLower()">
                                            @Localizer[$"AssignmentStatus_{wird.Status}"]
                                        </span>
                                        @if (wird.IsCompleted)
                                        {
                                            <span class="completion-badge">
                                                <i class='bx bx-check-circle'></i>
                                                @Localizer["Completed"]
                                            </span>
                                        }
                                    </div>
                                </div>
                            }
                        </div>

                        <!-- Pagination -->
                        <div class="pagination-controls">
                            <div class="pagination-info">
                                <span>@Localizer["Page"] @paginatedWirds.PageNumber @Localizer["Of"]
                                    @paginatedWirds.TotalPages
                                    (@paginatedWirds.TotalCount @Localizer["TotalRecords"])</span>
                            </div>
                            <div class="pagination-buttons">
                                @if (paginatedWirds.HasPreviousPage)
                                {
                                    <a asp-action="Details" asp-route-id="@student.UserId"
                                       asp-route-page="@(paginatedWirds.PageNumber - 1)"
                                       asp-route-tab="wirds" asp-route-status="@Model.WirdStatus" asp-route-type="@Model.WirdType"
                                       class="pagination-btn prev-btn">
                                        <i class='bx bx-chevron-left'></i>
                                        @Localizer["Previous"]
                                    </a>
                                }
                                else
                                {
                                    <button class="pagination-btn prev-btn" disabled>
                                        <i class='bx bx-chevron-left'></i>
                                        @Localizer["Previous"]
                                    </button>
                                }

                                <div class="page-numbers">
                                    @for (int i = 1; i <= paginatedWirds.TotalPages; i++)
                                    {
                                        if (i == paginatedWirds.PageNumber)
                                        {
                                            <span class="page-num active">@i</span>
                                        }
                                        else if (i == 1 || i == paginatedWirds.TotalPages ||
                                        (i >= paginatedWirds.PageNumber - 1 && i <= paginatedWirds.PageNumber + 1))
                                        {
                                            <a asp-action="Details" asp-route-id="@student.UserId"
                                               asp-route-page="@i"
                                               asp-route-tab="wirds" asp-route-status="@Model.WirdStatus" asp-route-type="@Model.WirdType"
                                               class="page-num">@i</a>
                                        }
                                        else if (i == 2 || i == paginatedWirds.TotalPages - 1)
                                        {
                                            <span class="page-num dots">...</span>
                                        }
                                    }
                                </div>

                                @if (paginatedWirds.HasNextPage)
                                {
                                    <a asp-action="Details" asp-route-id="@student.UserId"
                                       asp-route-page="@(paginatedWirds.PageNumber + 1)"
                                       asp-route-tab="wirds" asp-route-status="@Model.WirdStatus" asp-route-type="@Model.WirdType"
                                       class="pagination-btn next-btn">
                                        @Localizer["Next"]
                                        <i class='bx bx-chevron-right'></i>
                                    </a>
                                }
                                else
                                {
                                    <button class="pagination-btn next-btn" disabled>
                                        @Localizer["Next"]
                                        <i class='bx bx-chevron-right'></i>
                                    </button>
                                }
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="no-data">
                            <i class='bx bx-book-alt'></i>
                            <p>@Localizer["NoWirdAssignments"]</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Notes Tab -->
        <div id="notes" class="tab-content @(activeTab == "notes" ? "active" : "")">
            <div class="section-card">
                <div class="section-header">
                    <h2><i class='bx bx-note'></i> @Localizer["ParentNotes"]</h2>
                </div>
                <div class="section-content">
                    @if (parentNotes.Any())
                    {
                        <div class="notes-list">
                            @foreach (var note in parentNotes.OrderByDescending(n => n.CreatedAt))
                            {
                                <div class="note-item">
                                    <div class="note-header">
                                        <div class="note-author">
                                            <i class='bx bx-user-circle'></i>
                                            <span>@note.CreatedByUser.FirstName @note.CreatedByUser.SecondName</span>
                                        </div>
                                        <div class="note-meta">
                                            <span class="note-date">
                                                <i class='bx bx-time-five'></i>
                                                @note.CreatedAt.ToString("MMM dd, yyyy HH:mm")
                                            </span>
                                        </div>
                                    </div>
                                    <div class="note-content">
                                        @note.Content
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="no-data">
                            <i class='bx bx-notepad'></i>
                            <p>@Localizer["NoParentNotes"]</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function openTab(evt, tabName) {
        var tabContent = document.getElementsByClassName("tab-content");
        for (var i = 0; i < tabContent.length; i++) {
            tabContent[i].style.display = "none";
            tabContent[i].classList.remove("active");
        }

        var tabBtn = document.getElementsByClassName("tab-btn");
        for (var i = 0; i < tabBtn.length; i++) {
            tabBtn[i].classList.remove("active");
        }

        document.getElementById(tabName).style.display = "block";
        setTimeout(() => {
            document.getElementById(tabName).classList.add("active");
        }, 10);

        evt.currentTarget.classList.add("active");
    }
</script>
