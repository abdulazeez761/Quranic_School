@model IEnumerable<Hafiz.Models.Student>
@inject Microsoft.AspNetCore.Mvc.Localization.IViewLocalizer Localizer

@{
    ViewData["Title"] = @Localizer["Title"];
}
<!-- Page Header -->
<div class="d-flex justify-between align-center mb-lg flex-wrap gap-md">
    <div>
        <h2 class="section-title mb-sm">
            <i class='bx bx-user' style="color: var(--primary-green);"></i>
            @Localizer["PageTitle"]
        </h2>
        <p class="text-medium">@Localizer["PageDescription"]</p>
    </div>
    <div class="btn-group">
        <a asp-action="Create" class="btn btn-primary">
            <i class='bx bx-user-plus'></i>
            <span>@Localizer["AddNewStudent"]</span>
        </a>
        <a asp-action="Reports" class="btn btn-outline">
            <i class='bx bx-bar-chart-alt-2'></i>
            <span>@Localizer["Reports"]</span>
        </a>
        <button class="btn btn-outline" id="exportBtn">
            <i class='bx bx-download'></i>
            <span>@Localizer["Export"]</span>
        </button>
    </div>
</div>

<!-- Statistics Cards -->
@{
    var totalStudents = Model.Count();
    var totalClasses = Model.SelectMany(s => s.Classes).Select(c => c.Id).Distinct().Count();
    var studentsWithClasses = Model.Count(s => s.Classes.Any());
    var studentsWithoutClasses = totalStudents - studentsWithClasses;
}

<div class="grid-auto-fit mb-lg">
    <div class="card card-stat">
        <div class="card-stat-icon">
            <i class='bx bx-user'></i>
        </div>
        <div class="card-stat-content">
            <div class="card-stat-label">@Localizer["TotalStudents"]</div>
            <div class="card-stat-value">@totalStudents</div>
        </div>
    </div>

    <div class="card card-stat">
        <div class="card-stat-icon" style="background: var(--success);">
            <i class='bx bx-check-circle'></i>
        </div>
        <div class="card-stat-content">
            <div class="card-stat-label">@Localizer["WithClasses"]</div>
            <div class="card-stat-value">@studentsWithClasses</div>
        </div>
    </div>

    <div class="card card-stat">
        <div class="card-stat-icon" style="background: var(--warning);">
            <i class='bx bx-error'></i>
        </div>
        <div class="card-stat-content">
            <div class="card-stat-label">@Localizer["WithoutClasses"]</div>
            <div class="card-stat-value">@studentsWithoutClasses</div>
        </div>
    </div>

    <div class="card card-stat">
        <div class="card-stat-icon" style="background: var(--info);">
            <i class='bx bx-group'></i>
        </div>
        <div class="card-stat-content">
            <div class="card-stat-label">@Localizer["NumberOfClasses"]</div>
            <div class="card-stat-value">@totalClasses</div>
        </div>
    </div>
</div>

<!-- Students Table -->
<div class="table-container">
    <!-- Search and Filter Toolbar -->
    <div class="table-toolbar">
        <div class="table-search">
            <input type="text" id="searchInput" placeholder="@Localizer["SearchPlaceholder"]">
            <i class='bx bx-search'></i>
        </div>
        <div class="table-filters">
            <select class="form-select form-input-sm" id="classFilter">
                <option value="">@Localizer["AllClasses"]</option>
                @{
                    var allClasses = Model.SelectMany(s => s.Classes)
                    .Select(c => c.Name)
                    .Distinct()
                    .OrderBy(name => name);

                    foreach (var className in allClasses)
                    {
                        <option value="@className">@className</option>
                    }
                }
            </select>
            <button id="clearFilters" class="btn btn-outline btn-sm">
                <i class='bx bx-refresh'></i>
                <span class="d-none d-md-inline">@Localizer["Reset"]</span>
            </button>
        </div>
    </div>

    <!-- Records grid -->
    <div class="record-grid" id="studentsGrid">
        @if (Model != null && Model.Any())
        {
            int index = 0;
            foreach (var student in Model)
            {
                var classesData = string.Join(",", student.Classes.Select(c => c.Name));
                var hasClasses = student.Classes.Any();
                var firstClass = student.Classes.Select(c => c.Name).FirstOrDefault();
                var avatarVariant = index % 5;
                var badgeVariant = index % 2 == 0 ? "record-badge--green" : "record-badge--gold";

                <div class="record-card" data-firstname="@student.StudentInfo.FirstName.ToLower()"
                     data-secondname="@student.StudentInfo.SecondName.ToLower()" data-classes="@classesData">

                    <div class="record-card-header">
                        <div class="record-avatar record-avatar--@avatarVariant">
                            @student.StudentInfo.FirstName.Substring(0, 1)
                        </div>
                        <div class="record-identity">
                            <span class="record-name">@student.StudentInfo.FirstName @student.StudentInfo.SecondName</span>
                            @if (hasClasses)
                            {
                                <span class="record-badge @badgeVariant" title="@string.Join(", ", student.Classes.Select(c => c.Name))">
                                    <i class='bx bx-book'></i>
                                    <span>@firstClass</span>
                                </span>
                            }
                            else
                            {
                                <span class="record-badge record-badge--empty">
                                    <i class='bx bx-info-circle'></i>
                                    <span>@Localizer["NoClasses"]</span>
                                </span>
                            }
                        </div>
                    </div>

                    <div class="record-info">
                        <div class="record-info-row">
                            <i class='bx bx-user'></i>
                            <span class="record-info-value" title="@student.StudentInfo.Username">@student.StudentInfo.Username</span>
                        </div>
                        <div class="record-info-row">
                            <i class='bx bx-phone'></i>
                            <span class="record-info-value">@student.StudentInfo.PhoneNumber</span>
                        </div>
                    </div>

                    <div class="record-actions">
                        <a asp-action="Details" asp-route-id="@student.UserId" class="record-btn record-btn-view">
                            <i class='bx bx-show'></i>
                            <span>@Localizer["ViewDetails"]</span>
                        </a>
                        <a asp-action="Edit" asp-route-id="@student.UserId" class="record-btn record-btn-edit">
                            <i class='bx bx-edit'></i>
                            <span>@Localizer["Edit"]</span>
                        </a>
                        <form asp-action="Delete" asp-route-id="@student.UserId" method="post" class="delete-form">
                            <button type="submit" class="record-btn record-btn-delete"
                                    data-confirm-delete="@string.Format(Localizer["DeleteConfirmation"].Value, student.StudentInfo.FirstName, student.StudentInfo.SecondName)"
                                    data-tooltip="@Localizer["Delete"]">
                                <i class='bx bx-trash'></i>
                            </button>
                        </form>
                    </div>
                </div>
                index++;
            }
        }
        else
        {
            <div class="record-empty">
                <i class='bx bx-user-x'></i>
                <h3 class="record-empty-title">@Localizer["NoDataAvailable"]</h3>
                <p class="text-medium">@Localizer["NoStudentsAdded"]</p>
                <a asp-action="Create" class="btn btn-primary mt-md">
                    <i class='bx bx-user-plus'></i> @Localizer["AddNewStudent"]
                </a>
            </div>
        }
    </div>

    <!-- Table Footer -->
    <div class="table-footer">
        <div class="table-info">
            @Html.Raw(string.Format(Localizer["ShowingStudents"].Value,
            $"<strong><span id='visibleCount'>{totalStudents}</span></strong>",
                        $"<strong>{totalStudents}</strong>"))
        </div>
    </div>
</div>
@section scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script src="~/js/student/search.js" asp-append-version="true"></script>
    <script src="~/js/confirmModal.js" asp-append-version="true"></script>
}