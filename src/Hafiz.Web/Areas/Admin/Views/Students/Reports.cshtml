@model Hafiz.DTOs.Student.AdminStudentReportsViewModel
@inject Microsoft.AspNetCore.Mvc.Localization.IViewLocalizer Localizer

@{
    ViewData["Title"] = Localizer["ReportsTitle"];
    // Partials use ViewData to share the parent view's localizer, so they all
    // resolve keys against Reports.<culture>.resx without needing per-partial resx files.
    ViewData["Localizer"] = Localizer;

    var students = Model.Students;
}

<div class="admin-student-reports">
    <div class="reports-header">
        <div>
            <h2 class="section-title">
                <i class='bx bx-bar-chart-alt-2' style="color: var(--primary-green);"></i>
                @Localizer["ReportsTitle"]
            </h2>
            <p class="text-medium">@Localizer["ReportsDescription"]</p>
        </div>
        <a asp-controller="Students" asp-action="Index" class="back-btn">
            <i class='bx bx-arrow-back'></i>
            <span>@Localizer["BackToStudents"]</span>
        </a>
    </div>

    <partial name="_ReportsFilters" model="Model" />
    <partial name="_ReportsSummaryStats" model="students" />

    @if (students.Any())
    {
        <partial name="_ReportsSortToolbar" model="Model" />

        <div class="report-cards d-none-mobile">
            @foreach (var row in students)
            {
                <partial name="_ReportCard" model="row" />
            }
        </div>

        <div class="report-list-mobile d-none-desktop" data-accordion>
            @foreach (var row in students)
            {
                <partial name="_ReportRowMobile" model="row" />
            }
        </div>
    }
    else
    {
        <div class="no-data">
            <i class='bx bx-search-alt'></i>
            <p>@Localizer["NoStudentsFound"]</p>
        </div>
    }
</div>

@section Scripts {
    <script src="~/js/admin-student-reports.js" asp-append-version="true"></script>
}
